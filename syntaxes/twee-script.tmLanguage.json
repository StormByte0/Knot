{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Twee Embedded Languages",
  "scopeName": "source.twee.embedded",
  "injectionSelector": "L:source.twee - (comment)",
  "patterns": [
    {
      "include": "#script-passage"
    },
    {
      "include": "#stylesheet-passage"
    },
    {
      "include": "#script-macro"
    },
    {
      "include": "#macro-js-args"
    },
    {
      "include": "#html-content"
    }
  ],
  "repository": {
    "script-passage": {
      "comment": "Full JS embedding for [script]-tagged passages and Story JavaScript.",
      "begin": "^(::[ \\t]+(?:Story JavaScript|[^\\n\\[{]*\\[[^\\]]*\\bscript\\b[^\\]]*\\])[^\\n]*)$",
      "end": "^(?=::)",
      "beginCaptures": {
        "1": {
          "name": "meta.passage.header.twee"
        }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "stylesheet-passage": {
      "comment": "Full CSS embedding for [stylesheet]/[style]-tagged passages.",
      "begin": "^(::[ \\t]+(?:Story Stylesheet|[^\\n\\[{]*\\[[^\\]]*\\b(?:stylesheet|style)\\b[^\\]]*\\])[^\\n]*)$",
      "end": "^(?=::)",
      "beginCaptures": {
        "1": {
          "name": "meta.passage.header.twee"
        }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "script-macro": {
      "comment": "Full JS embedding inside <<script>>...<</script>> block macro bodies.",
      "begin": "(<<)(script)(>>)",
      "end": "(<</)(script)(>>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.macro.begin.twee"
        },
        "2": {
          "name": "entity.name.function.macro.twee"
        },
        "3": {
          "name": "punctuation.definition.macro.end.twee"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.macro.begin.twee"
        },
        "2": {
          "name": "entity.name.function.macro.twee"
        },
        "3": {
          "name": "punctuation.definition.macro.end.twee"
        }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "macro-js-args": {
      "comment": "JS highlighting for expression-bearing macros.",
      "patterns": [
        {
          "include": "#macro-js-args-expr"
        },
        {
          "include": "#macro-js-args-print"
        }
      ]
    },
    "macro-js-args-expr": {
      "comment": "Remove applyEndPatternLast so >> end is checked before source.js right-shift",
      "begin": "(<<)(=|-)(\\s*)",
      "end": "(>>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.macro.begin.twee" },
        "2": { "name": "entity.name.function.macro.twee" },
        "3": { "name": "meta.embedded.block.javascript" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.macro.end.twee" }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        { "include": "source.js" }
      ]
    },
    "macro-js-args-print": {
      "begin": "(<<)(run|set|if|elseif|for|print|unset)(?=[\\s>])",
      "end": "(>>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.macro.begin.twee" },
        "2": { "name": "entity.name.function.macro.twee" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.macro.end.twee" }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "comment": "Protect >> inside double-quoted strings from being seen as end pattern",
          "match": "\"(?:[^\"\\\\]|\\\\.)*\"",
          "name": "string.quoted.double.js"
        },
        {
          "comment": "Protect >> inside single-quoted strings",
          "match": "'(?:[^'\\\\]|\\\\.)*'",
          "name": "string.quoted.single.js"
        },
        {
          "comment": "Protect >> inside block comments",
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.js"
        },
        { "include": "#sugarcube-operators" },
        { "include": "source.js" }
      ]
    },
    "sugarcube-operators": {
      "comment": "SugarCube keyword operators that are not valid JS — highlight as operators.",
      "match": "(?<![\\w$])(to|eq|neq|gt|gte|lt|lte|and|or|not|is|isnot)(?![\\w$])",
      "name": "keyword.operator.sugarcube.twee"
    },
    "html-content": {
      "comment": "HTML tag highlighting in markup passage bodies.",
      "patterns": [
        {
          "include": "#html-block-tag"
        },
        {
          "include": "#html-void-tag"
        },
        {
          "include": "#html-close-tag"
        }
      ]
    },
    "html-block-tag": {
      "begin": "(<)((?:[A-Za-z][A-Za-z0-9-]*))(\\b)(?!\\s*/?>)",
      "end": "(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "patterns": [
        {
          "include": "#html-attribute"
        }
      ]
    },
    "html-void-tag": {
      "begin": "(<)((?:area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr))(\\b)",
      "end": "(/?>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        }
      },
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "patterns": [
        {
          "include": "#html-attribute"
        }
      ]
    },
    "html-close-tag": {
      "match": "(</)([A-Za-z][A-Za-z0-9-]*)(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      }
    },
    "html-attribute": {
      "patterns": [
        {
          "begin": "([A-Za-z_:][A-Za-z0-9_.:-]*)\\s*(=)\\s*(\")",
          "end": "(\")",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.html"
            },
            "2": {
              "name": "punctuation.separator.key-value.html"
            },
            "3": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.html"
            }
          },
          "contentName": "string.quoted.double.html",
          "patterns": [
            {
              "include": "#style-attr-value"
            },
            {
              "include": "#html-entity"
            }
          ]
        },
        {
          "begin": "([A-Za-z_:][A-Za-z0-9_.:-]*)\\s*(=)\\s*(')",
          "end": "(')",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.html"
            },
            "2": {
              "name": "punctuation.separator.key-value.html"
            },
            "3": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.html"
            }
          },
          "contentName": "string.quoted.single.html",
          "patterns": [
            {
              "include": "#html-entity"
            }
          ]
        },
        {
          "match": "[A-Za-z_:][A-Za-z0-9_.:-]*",
          "name": "entity.other.attribute-name.html"
        }
      ]
    },
    "style-attr-value": {
      "match": "([a-z][a-z-]*)\\s*(:)\\s*([^;\"']+)",
      "captures": {
        "1": {
          "name": "support.type.property-name.css"
        },
        "2": {
          "name": "punctuation.separator.key-value.css"
        },
        "3": {
          "name": "meta.property-value.css"
        }
      }
    },
    "html-entity": {
      "match": "&(?:[A-Za-z]+|#[0-9]+|#x[0-9A-Fa-f]+);",
      "name": "constant.character.entity.html"
    }
  }
}