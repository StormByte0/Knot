{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/tc39-proposal-json-parse-with-source/main/textmate-grammar.json",
  "scopeName": "source.twee.embedded",
  "name": "Twee Embedded",
  "injectionSelector": "L:source.twee",
  "patterns": [
    {
      "comment": "Embedded JavaScript in [script] passages — entire passage body after header",
      "begin": "^(::\\s*[^\\[\\]\\n]*\\[script\\])\\s*\\n",
      "beginCaptures": {
        "1": {
          "patterns": [
            {
              "match": "(::)\\s*",
              "captures": {
                "1": { "name": "punctuation.definition.passage.begin.twee" }
              }
            },
            {
              "match": "[^\\[\\]\\s][^\\[\\]\\n]*",
              "name": "entity.name.section.passage.twee"
            },
            {
              "match": "\\[",
              "name": "punctuation.definition.tag.begin.twee"
            },
            {
              "match": "script",
              "name": "entity.other.attribute-name.tag.twee"
            },
            {
              "match": "\\]",
              "name": "punctuation.definition.tag.end.twee"
            }
          ]
        }
      },
      "end": "^(?=::)",
      "patterns": [
        {
          "contentName": "meta.embedded.block.javascript",
          "begin": "(?<=\\n)",
          "end": "^(?=::)",
          "patterns": [
            {
              "include": "source.js"
            }
          ]
        }
      ]
    },
    {
      "comment": "Embedded CSS in [stylesheet] passages — entire passage body after header",
      "begin": "^(::\\s*[^\\[\\]\\n]*\\[stylesheet\\])\\s*\\n",
      "beginCaptures": {
        "1": {
          "patterns": [
            {
              "match": "(::)\\s*",
              "captures": {
                "1": { "name": "punctuation.definition.passage.begin.twee" }
              }
            },
            {
              "match": "[^\\[\\]\\s][^\\[\\]\\n]*",
              "name": "entity.name.section.passage.twee"
            },
            {
              "match": "\\[",
              "name": "punctuation.definition.tag.begin.twee"
            },
            {
              "match": "stylesheet",
              "name": "entity.other.attribute-name.tag.twee"
            },
            {
              "match": "\\]",
              "name": "punctuation.definition.tag.end.twee"
            }
          ]
        }
      },
      "end": "^(?=::)",
      "patterns": [
        {
          "contentName": "meta.embedded.block.css",
          "begin": "(?<=\\n)",
          "end": "^(?=::)",
          "patterns": [
            {
              "include": "source.css"
            }
          ]
        }
      ]
    },
    {
      "comment": "Inline <script> blocks within any passage",
      "begin": "(<script\\b)(?=[^>]*>)(.*?)(>)",
      "beginCaptures": {
        "1": { "name": "entity.name.tag.script.html" },
        "2": { "name": "meta.tag.attributes.html" },
        "3": { "name": "entity.name.tag.script.html" }
      },
      "end": "(</script>)",
      "endCaptures": {
        "1": { "name": "entity.name.tag.script.html" }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    {
      "comment": "Inline <style> blocks within any passage",
      "begin": "(<style\\b)(?=[^>]*>)(.*?)(>)",
      "beginCaptures": {
        "1": { "name": "entity.name.tag.style.html" },
        "2": { "name": "meta.tag.attributes.html" },
        "3": { "name": "entity.name.tag.style.html" }
      },
      "end": "(</style>)",
      "endCaptures": {
        "1": { "name": "entity.name.tag.style.html" }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    {
      "comment": "SugarCube <<script>> macro blocks",
      "begin": "(<<)(script)(>>)\\s*",
      "beginCaptures": {
        "1": { "name": "keyword.operator.twee" },
        "2": { "name": "entity.name.function.macro.twee" },
        "3": { "name": "keyword.operator.twee" }
      },
      "end": "(<<)(/script)(>>)",
      "endCaptures": {
        "1": { "name": "keyword.operator.twee" },
        "2": { "name": "entity.name.function.macro.twee" },
        "3": { "name": "keyword.operator.twee" }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    {
      "comment": "SugarCube <<style>> macro blocks",
      "begin": "(<<)(style)(>>)\\s*",
      "beginCaptures": {
        "1": { "name": "keyword.operator.twee" },
        "2": { "name": "entity.name.function.macro.twee" },
        "3": { "name": "keyword.operator.twee" }
      },
      "end": "(<<)(/style)(>>)",
      "endCaptures": {
        "1": { "name": "keyword.operator.twee" },
        "2": { "name": "entity.name.function.macro.twee" },
        "3": { "name": "keyword.operator.twee" }
      },
      "contentName": "meta.embedded.block.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    }
  ]
}
