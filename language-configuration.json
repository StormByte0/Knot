{
  "comments": {
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["<<", ">>"],
    ["[[", "]]"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "<<", "close": ">>", "notIn": ["string", "comment"] },
    { "open": "[[", "close": "]]", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open":"/*", "close": "*/"}
  ],
  "autoCloseBefore": ">]})'\"`\n ",
  "surroundingPairs": [
    ["<<", ">>"],
    ["[[", "]]"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "indentationRules": {
    "increaseIndentPattern": "<<(?:if|elseif|else|for|switch|case|widget|link|button|script|capture|nobr|silently)\\b.*>>",
    "decreaseIndentPattern": "<</(?:if|for|switch|case|widget|link|button|script|capture|nobr|silently)>>"
  },
  "folding": {
    "markers": {
      "start": "^::",
      "end": "^::"
    }
  },
  "onEnterRules": [
    {
      "beforeText": "<<(if|elseif|else|for|switch|widget|link|button|capture|silently|nobr|script).*>>\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}
