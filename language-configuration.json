{
  "comments": {
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["<<", ">>"],
    ["[[", "]]"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "<<", "close": ">>", "notIn": ["string", "comment"] },
    { "open": "[[", "close": "]]", "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open":"/*", "close": "*/"}
  ],
  "autoCloseBefore": ">]})'\"`\n ",
  "surroundingPairs": [
    ["<<", ">>"],
    ["[[", "]]"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}