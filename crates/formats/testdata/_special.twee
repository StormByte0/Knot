    consumable: false, effects: null
    /* Use::makeup-kit passage handles same grooming interface */
  },

  /* -- DOCUMENTS ------------------------------------------------ */
  "case-folder": {
    name: "Case Folder", description: "Holds the active request set for the afternoon window.",
    category: "document", type: "document", slot: null, zIndex: null,
    image: "test.png", tags: ["folder","work","active"], value: 0,
    consumable: false, effects: null
  },
  "compliance-memo": {
    name: "Compliance Memo", description: "This week's inspection priorities. Keep it somewhere visible.",
    category: "document", type: "document", slot: null, zIndex: null,
    image: "test.png", tags: ["memo","compliance","work"], value: 0,
    consumable: false, effects: null
  }

}>>


/* ----------------------------------------------------------------
   NPCS  ($NPCS)
   Static data for every named character. Dynamic relationship state
   is tracked in $gs.npcs keyed by the same keys.

   Shape:
   {
     name:         string   Display name
     description:  string   Brief character note shown on hover / inspect
     image:        string   Filename only (e.g. "supervisor-holt.png")
                            Rendered from: images/npcs/<image>
                            Must be 1:2 aspect ratio, transparent background
                            Minimum production width: 400px
     defaultState: object   Initial values written to $gs.npcs[key] on first
                            encounter. Keys are arbitrary — define whatever
                            relationship axes the story uses.
                            Common axes: affection, anger, trust, suspicion
                            Range convention: 0-100 for all axes
   }
---------------------------------------------------------------- */
<<set $NPCS = {
  "supervisor-holt": {
    name: "Supervisor Holt",
    description: "Middle management. Watches the door more than the work.",
    image: "test.png",
    defaultState: { affection: 40, anger: 20, trust: 30, suspicion: 25 }
  },
  "clerk-osei": {
    name: "Clerk Osei",
    description: "Two desks over. Reliable. Knows where everything is filed.",
    image: "test.png",
    defaultState: { affection: 60, anger: 5,  trust: 50, suspicion: 5  }
  },
  "auditor-voss": {
    name: "Auditor Voss",
    description: "Compliance division. Here for the week. Taking notes.",
    image: "test.png",
    defaultState: { affection: 20, anger: 10, trust: 15, suspicion: 60 }
  }
}>>


/* ----------------------------------------------------------------
   SCENES  ($SCENES)
   Default visual and descriptive data per location.
   $gs.scene.image and $gs.scene.description override these when
   non-null. Use <<setSceneLoc>> to switch locations.

   Shape:
   {
     title:       string        Display name shown in sector-2
     image:       string | null Filename only (e.g. "records-desk.jpg")
                                Rendered from: images/scenes/<image>
                                Must be 5:2 aspect ratio
                                Minimum production width: 1200px
                                null if no art yet
     description: string        Default descriptive text for the scene
                                Shown in Scene::<id> passage if no override
   }
---------------------------------------------------------------- */
<<set $SCENES = {
  "records-desk":       { title: "Records Desk",         image: "test.png", description: "You sit at the records desk, away from the phones, with a neat stack of requests waiting for review." },
  "file-review-bay":    { title: "File Review Bay",      image: "test.png", description: "You move from folder to folder, logging each discrepancy before it can become someone else's problem." },
  "break-room":         { title: "Break Room",           image: "test.png", description: "The humming vending machine and a lukewarm coffee buy you ten minutes of peace." },
  "compliance-bulletin":{ title: "Compliance Bulletin",  image: "test.png", description: "A fresh memo outlines the week's inspection priorities and reminds everyone to keep their stations immaculate." },
  "overflow-archive":   { title: "Overflow Archive",     image: "test.png", description: "You stay with the backlog long enough for the office lights to feel harsher than usual." },
  "hallway":            { title: "Hallway",              image: "test.png", description: "A quick conversation reminds you that everyone is improvising their way through policy and pressure." },
  "locker-room":        { title: "Locker Room",          image: "test.png", description: "The narrow corridor of lockers. The mirror at the end reflects whoever you've decided to be today." }
}>>


/* ----------------------------------------------------------------
   SCHEDULE  ($SCHEDULE)
   Seven-day work schedule template. Index 0 = Monday, 6 = Sunday.
   This is reference data — the schedule is not enforced. It provides
   shift labels for the UI and base pay rates for payout calculations.
   $gs.time.context is set explicitly by passage authors via
   <<setContext>>, not derived from this schedule.

   Shape (each day):
   {
     label:  string    Day name
     shifts: array     Each shift: { start, end, label, context, baseRate }
       start:    int   Hour (0-23) when shift begins (inclusive)
       end:      int   Hour (0-23) when shift ends (exclusive)
       label:    string Display label ("Morning", "Afternoon", etc.)
       context:  string "work" | "off" | "transit" | "personal"
       baseRate: int   Cents per in-game minute while context = "work"
                       0 for non-work shifts
   }
---------------------------------------------------------------- */
<<set $SCHEDULE = [
  { label: "Monday",    shifts: [ { start: 9,  end: 13, label: "Morning",   context: "work", baseRate: 14 }, { start: 13, end: 14, label: "Lunch",     context: "off",  baseRate: 0  }, { start: 14, end: 17, label: "Afternoon", context: "work", baseRate: 14 } ] },
  { label: "Tuesday",   shifts: [ { start: 9,  end: 13, label: "Morning",   context: "work", baseRate: 14 }, { start: 13, end: 14, label: "Lunch",     context: "off",  baseRate: 0  }, { start: 14, end: 17, label: "Afternoon", context: "work", baseRate: 14 } ] },
  { label: "Wednesday", shifts: [ { start: 9,  end: 13, label: "Morning",   context: "work", baseRate: 14 }, { start: 13, end: 14, label: "Lunch",     context: "off",  baseRate: 0  }, { start: 14, end: 18, label: "Afternoon", context: "work", baseRate: 14 } ] },
  { label: "Thursday",  shifts: [ { start: 9,  end: 13, label: "Morning",   context: "work", baseRate: 14 }, { start: 13, end: 14, label: "Lunch",     context: "off",  baseRate: 0  }, { start: 14, end: 17, label: "Afternoon", context: "work", baseRate: 14 } ] },
  { label: "Friday",    shifts: [ { start: 9,  end: 13, label: "Morning",   context: "work", baseRate: 16 }, { start: 13, end: 14, label: "Lunch",     context: "off",  baseRate: 0  }, { start: 14, end: 16, label: "Afternoon", context: "work", baseRate: 16 } ] },
  { label: "Saturday",  shifts: [] },
  { label: "Sunday",    shifts: [] }
]>>


/*
  ================================================================
  GAME STATE  ($gs)
  ================================================================
  Single serialisable object. All save/load operates on $gs.
  Registries ($SLOTS, $ITEMS, $NPCS, $SCENES, $SCHEDULE) are never
  saved — they are reconstituted from StoryInit on every load.
  ================================================================
*/
<<set $gs = {

  /* -- TIME ----------------------------------------------------
     week:    int   0-indexed from game start
     day:     int   0 = Monday ... 6 = Sunday
     hour:    int   0-23
     minute:  int   0-59
     context: string  "work" | "off" | "transit" | "personal"
              Set explicitly via <<setContext>>.
              NOT derived from $SCHEDULE automatically.
              Performance meters only increment when context = "work".
  */
  time: {
    week:    0,
    day:     0,
    hour:    11,
    minute:  40,
    context: "work"
  },

  /* -- STATS ---------------------------------------------------
     All values clamped 0-100 by <<adjustStat>>.
     Add new stat keys here to make them available to <<adjustStat>>.
  */
  stats: {
    stress:  35,
    stamina: 60
  },

  /* -- FINANCE -------------------------------------------------
     All values in cents (int) to avoid floating-point errors.
     balance: 112000 = $1,120.00
     debt:    840000 = $8,400.00
  */
  finance: {
    balance: 112000,
    debt:    840000
  },

  /* -- PERFORMANCE ---------------------------------------------
     Resets after each salary payout cycle.
     score:              float  Weighted quality accumulator
     tasksCompleted:     int    Discrete task count this cycle
     minutesInWork:      int    In-game minutes while context = "work"
     cycleStartDay:      int    Day the current cycle began
     cycleStartWeek:     int    Week the current cycle began
     payoutIntervalDays: int    Days between payouts (7 = weekly)
     baseSalary:         int    Cents paid at each payout unconditionally
     bonusThreshold:     float  Score required to earn the bonus
     bonusAmount:        int    Cents added when score >= bonusThreshold
  */
  performance: {
    score:              0.0,
    tasksCompleted:     0,
    minutesInWork:      0,
    cycleStartDay:      0,
    cycleStartWeek:     0,
    payoutIntervalDays: 7,
    baseSalary:         180000,
    bonusThreshold:     50.0,
    bonusAmount:        25000
  },

  /* -- STATUS --------------------------------------------------
     strikes: 0-3. Three strikes triggers a game-over check.
              Check $gs.status.strikes in passages after <<warn>>.
  */
  status: {
    strikes: 1
  },

  /* -- SCENE ---------------------------------------------------
     id:          string        Key into $SCENES
     image:       string | null null = use $SCENES[id].image
                                string = override for this passage only
     description: string | null null = use $SCENES[id].description
     npcs:        string[]      NPC keys declared by the current passage.
                                Reset to [] at the start of every scene render.
                                Populated by <<setNPC>> calls in the passage.
  */
  scene: {
    id:          "records-desk",
    image:       null,
    description: null,
    npcs:        []
  },

  /* -- INVENTORY -----------------------------------------------
     states: object  itemKey -> "locked" | "world" | "carried" | "equipped"
       "locked"   Item does not yet exist in the world
       "world"    Exists somewhere but not with the player
       "carried"  In the player's bag (not occupying a slot)
       "equipped" In a body slot (see equipped map below)
       Keys absent from states are implicitly "locked".

     equipped: object  slotKey -> itemKey | null
       Authoritative slot contents.
       Must remain in sync with states at all times.
       Only <<equipItem>> and <<unequipItem>> should mutate both.
  */
  inventory: {
    states: {
      "plain-bra-white":       "equipped",
      "plain-underwear-white": "equipped",
      "sheer-tights-nude":     "equipped",
      "pencil-skirt-navy":     "equipped",
      "blouse-white-button":   "equipped",
      "blazer-navy":           "equipped",
      "heels-black-low":       "equipped",
      "tote-black":            "equipped",
      "name-badge":            "equipped",
      "ink-pen":               "carried",
      "ledger-key":            "carried",
      "case-folder":           "carried",
      "hand-mirror":           "world",
      "compliance-memo":       "world",
      "plain-bra-black":       "locked",
      "sheer-tights-black":    "locked",
      "trousers-charcoal":     "locked",
      "blouse-ivory-silk":     "locked",
      "cardigan-grey":         "locked",
      "corset-black":          "locked",
      "flats-nude":            "locked",
      "briefcase-tan":         "locked",
      "watch-silver":          "locked",
      "visitor-pass":          "locked",
      "coffee-cup":            "world",
      "energy-drink":          "locked",
      "painkiller":            "world",
      "makeup-kit":            "world"
    },
    equipped: {
      "underwear-top":    "plain-bra-white",
      "underwear-bottom": "plain-underwear-white",
      "legwear":          "sheer-tights-nude",
      "bottom":           "pencil-skirt-navy",
      "top":              "blouse-white-button",
      "dress":            null,
      "outerwear":        "blazer-navy",
      "shoes":            "heels-black-low",
      "head":             null,
      "bag":              "tote-black",
      "accessory-left":   null,
      "accessory-right":  null,
      "accessory-neck":   null,
      "badge":            "name-badge"
    }
  },

  /* -- NPC RELATIONSHIP STATE ----------------------------------
     Keys match $NPCS. Values start from $NPCS[key].defaultState
     and are mutated by gameplay events.
     Initialised lazily on first <<setNPC>> or relationship macro
     call — not pre-populated here to avoid maintenance burden
     when new NPCs are added to $NPCS.
     Structure once populated:
       "supervisor-holt": { affection: 40, anger: 20, trust: 30, suspicion: 25 }
  */
  npcs: {},

  /* -- JOURNAL -------------------------------------------------
     Quest and objective tracker. Not a chronological activity log.
     quests: array of quest objects:
       id:      string  Unique identifier — used by <<questLog>> and <<questStatus>>
       title:   string  Display name shown in journal tab
       status:  string  "hidden" | "active" | "complete" | "failed"
                        hidden quests are never shown in the journal tab
       entries: array   Objectives and notes appended by <<questLog>>
         text:    string  Objective text displayed in journal
         week:    int     Time of entry (stored for reference, not displayed)
         day:     int
         hour:    int
         minute:  int
  */
  journal: {
    quests: [
      {
        id:     "first-day",
        title:  "Getting Through the Day",
        status: "active",
        entries: [
          { text: "Arrive on time for the filing window.",   week: 0, day: 0, hour: 8,  minute: 0  },
          { text: "Review witness statements before lunch.", week: 0, day: 0, hour: 9,  minute: 15 },
          { text: "Keep the desk clear for inspections.",   week: 0, day: 0, hour: 10, minute: 30 }
        ]
      }
    ]
  },

  /* -- META ----------------------------------------------------
     Runtime flags and UI state that must persist across saves.

     uiProfile: int    Index into $UI_PROFILES. Controls which
                       sidebar profile is currently active.
                       Change with <<setProfile n>>.
     employed:  bool   True once the player has a job. Used by
                       showIf in sidebar profile specs to hide/show
                       employment-dependent cards.
     debug:     bool   When true, profile spec validation runs on
                       startup and logs warnings to browser console.
                       Set true during authoring; false for release.
  */
  meta: {
    uiProfile: 0,
    employed:  false,
    debug:     false
  }

}>>


/* ----------------------------------------------------------------
   UI PROFILES  ($UI_PROFILES)
   ----------------------------------------------------------------
   Array of sidebar profile specs. Index matches $gs.meta.uiProfile.
   Profiles are read-only display configuration — never saved in $gs.
   Change the active profile at runtime with <<setProfile n>>.

   Profile shape:
   {
     id:      string          Unique label for debug messages
     extends: int | null      Index of parent profile to inherit from.
                              Child cards REPLACE parent cards at the
                              same array index. To add a card, append
                              at a new index; to change a card, copy
                              and modify at the same index.
     left:    array of cards  See card shape below.
   }

   Card shape:
   {
     title:  string | null  Optional card header label
     showIf: string | null  Dotted VM path resolving to boolean.
                            null = always shown.
                            Path must exist on the ViewModel.
                            Example: "meta.employed"
     rows:   array of rows  Each row is an array of element specs.
                            One element = full width.
                            Two elements = split 50/50.
   }

   Element spec shape:
   {
     t:      string   Primitive type. One of:
                        "string"   — label + text value
                        "number"   — label + formatted number
                        "progress" — label + continuous fill bar (0-100)
                        "steps"    — label + N discrete pip cells
     label:  string   Display label shown above/beside the value
     v:      string   Dotted path into the ViewModel.
                      Example: "stats.stress", "dateLabel", "finance.balance"
     fmt:    string   Optional formatter. Valid values:
                        "percent"  — appends %  (for string/number)
                        "money"    — cents to $X,XXX (for number)
                        "int"      — Math.round (for number)
     min:    number   Optional. Lower bound for progress (default 0)
     max:    number   Optional. Upper bound for progress/steps (default 100)
     style:  string   Optional visual variant.
                        "danger"   — red fill (progress)
                        "good"     — green fill (progress, default)
                        "warning"  — amber fill (progress/steps)
     showIf: string | null  Same as card-level showIf but for this
                            element only. Hides single cell.
   }

   ViewModel paths available to v and showIf:
     dateLabel          — formatted "Mon · Mar 18" string
     timeLabel          — formatted "11:40 AM" string
     shiftLabel         — shift name from $SCHEDULE or "Off"
     stats.stress       — int 0-100
     stats.stamina      — int 0-100
     finance.balance    — int cents
     finance.debt       — int cents
     status.strikes     — int 0-3
     performance.score  — float
     performance.tasksCompleted  — int
     meta.employed      — bool
     meta.uiProfile     — int
     meta.debug         — bool
---------------------------------------------------------------- */
<<set $UI_PROFILES = [

  /* -- PROFILE 0: base (pre-employment) ------------------------
     Shown from game start. No shift or employment indicators.
     Extend this for employed stages.
  */
  {
    id:      "base",
    extends: null,
    left: [

      /* Card 0 — Date, time, shift */
      {
        title:  null,
        showIf: null,
        rows: [
          [
            { t: "string", label: "Date",  v: "dateLabel",  fmt: null, showIf: null },
            { t: "string", label: "Time",  v: "timeLabel",  fmt: null, showIf: null }
          ],
          [
            { t: "string", label: "Shift", v: "shiftLabel", fmt: null, showIf: "meta.employed" }
          ]
        ]
      },

      /* Card 1 — Stress and stamina */
      {
        title:  null,
        showIf: null,
        rows: [
          [ { t: "progress", label: "Stress",  v: "stats.stress",  min: 0, max: 100, style: "danger", showIf: null } ],
          [ { t: "progress", label: "Stamina", v: "stats.stamina", min: 0, max: 100, style: "good",   showIf: null } ]
        ]
      },

      /* Card 2 — Finance and warnings */
      {
        title:  null,
        showIf: null,
        rows: [
          [
            { t: "number", label: "Balance", v: "finance.balance", fmt: "money",   showIf: null },
            { t: "number", label: "Debt",    v: "finance.debt",    fmt: "money",   showIf: null }
          ],
          [
            { t: "steps", label: "Warnings", v: "status.strikes", max: 3, style: "danger", showIf: null }
          ]
        ]
      }

    ]
  },

  /* -- PROFILE 1: employed ------------------------------------
     Extends profile 0. Shift row is now visible (meta.employed = true).
     Add employment-specific cards here.
  */
  {
    id:      "employed",
    extends: 0,
    left: [
      /* Card 0 overrides profile 0 card 0 — same structure,
         shift row showIf removed so it always shows */
      {
        title:  null,
        showIf: null,
        rows: [
          [
            { t: "string", label: "Date",  v: "dateLabel",  fmt: null, showIf: null },
            { t: "string", label: "Time",  v: "timeLabel",  fmt: null, showIf: null }
          ],
          [
            { t: "string", label: "Shift", v: "shiftLabel", fmt: null, showIf: null }
          ]
        ]
      }
      /* Cards 1 and 2 inherited from profile 0 unchanged */
    ]
  }
]>>
