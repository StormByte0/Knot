  /* -- COSMETICS ------------------------------------------------
     Items with a Use::<key> passage are Category B items.
     Their use action routes to that passage in sector-3.
     The passage handles all conditional logic (paired items, etc.).
  ---------------------------------------------------------------- */
  "hand-mirror": {
    name: "Hand Mirror", description: "Small enough to fit in any bag. Useful before any meeting.",
    category: "cosmetic", type: "tool", slot: null, zIndex: null,
