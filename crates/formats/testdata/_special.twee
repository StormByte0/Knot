    category: "apparel", type: "outerwear", slot: "outerwear", zIndex: 6,
    image: "test.png", tags: ["blazer","navy","office","formal"], value: 8900,
    consumable: false, effects: null
  },
  "cardigan-grey": {
    name: "Grey Cardigan", description: "Casual. Acceptable on Fridays only, technically.",
