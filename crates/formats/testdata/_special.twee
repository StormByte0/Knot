    consumable: false, effects: null
  },
  "flats-nude": {
    name: "Nude Ballet Flats", description: "Quiet. Practical. Invisible in the best way.",
    category: "apparel", type: "shoes", slot: "shoes", zIndex: 7,
    image: "test.png", tags: ["flats","nude","office","comfortable"], value: 4200,
    consumable: false, effects: null
  },

  /* -- BAGS ----------------------------------------------------- */
  "tote-black": {
    name: "Black Canvas Tote", description: "Holds everything. Shows nothing.",
    category: "apparel", type: "bag", slot: "bag", zIndex: 9,
    image: "test.png", tags: ["bag","black","canvas","large"], value: 2200,
    consumable: false, effects: null
  },
  "briefcase-tan": {
    name: "Tan Leather Briefcase", description: "Inherited, or found. Either way it projects authority.",
    category: "apparel", type: "bag", slot: "bag", zIndex: 9,
    image: "test.png", tags: ["bag","tan","leather","formal"], value: 12000,
    consumable: false, effects: null
  },

  /* -- ACCESSORIES ---------------------------------------------- */
  "watch-silver": {
    name: "Silver Wristwatch", description: "Analogue. A quiet statement of punctuality.",
    category: "apparel", type: "accessory", slot: "accessory-left", zIndex: 10,
    image: "test.png", tags: ["watch","silver","accessory"], value: 8000,
    consumable: false, effects: null
  },

  /* -- BADGES --------------------------------------------------- */
  "name-badge": {
    name: "Staff Name Badge", description: "Policy requires it visible at all times on the floor.",
    category: "apparel", type: "badge", slot: "badge", zIndex: 13,
    image: "test.png", tags: ["badge","id","required","staff"], value: 0,
    consumable: false, effects: null
  },
  "visitor-pass": {
    name: "Visitor Pass", description: "A laminated single-day access card. Expires at midnight.",
    category: "apparel", type: "badge", slot: "badge", zIndex: 13,
