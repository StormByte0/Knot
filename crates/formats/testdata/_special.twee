::StoryInit

/*
  ================================================================
  REGISTRIES
  ================================================================
  Read-only master definitions. Set once here, never mutated.
  Dynamic state for all entities lives exclusively in $gs.
  All registry values are accessed by key string.

  Registry shape contracts are documented in AUTHORING.md.
  ================================================================
*/


/* ----------------------------------------------------------------
   BODY SLOTS  ($SLOTS)
   Canonical equip slots in canvas render order (ascending zIndex).

   Shape:
   {
     label:        string   Display name shown in inventory UI
     zIndex:       int      Canvas layer order (lower = drawn first)
     allowedTypes: string[] Item type strings that may occupy this slot
     description:  string   Tooltip / flavour text for the slot
   }
---------------------------------------------------------------- */
<<set $SLOTS = {
  "underwear-top":    { label: "Underwear Top",     zIndex: 1,  allowedTypes: ["underwear-top"],                  description: "Worn directly against the skin, torso." },
  "underwear-bottom": { label: "Underwear Bottom",  zIndex: 2,  allowedTypes: ["underwear-bottom"],               description: "Worn directly against the skin, lower body." },
  "legwear":          { label: "Legwear",           zIndex: 3,  allowedTypes: ["legwear"],                        description: "Stockings, tights, socks." },
  "bottom":           { label: "Bottom",            zIndex: 4,  allowedTypes: ["bottom"],                         description: "Skirt, trousers, shorts." },
  "top":              { label: "Top",               zIndex: 5,  allowedTypes: ["top"],                            description: "Blouse, shirt, knit." },
  "dress":            { label: "Dress / Jumpsuit",  zIndex: 5,  allowedTypes: ["dress"],                          description: "One-piece garments. Conflicts with top + bottom." },
  "outerwear":        { label: "Outerwear",         zIndex: 6,  allowedTypes: ["outerwear"],                      description: "Blazer, cardigan, coat, vest, corset." },
  "shoes":            { label: "Shoes",             zIndex: 7,  allowedTypes: ["shoes"],                          description: "Footwear." },
  "head":             { label: "Head",              zIndex: 8,  allowedTypes: ["hat","hair-accessory"],           description: "Hats, fascinators, headbands." },
  "bag":              { label: "Bag",               zIndex: 9,  allowedTypes: ["bag"],                            description: "Handbag, tote, briefcase." },
  "accessory-left":   { label: "Left Accessory",   zIndex: 10, allowedTypes: ["accessory"],                      description: "Ring, bracelet, watch (left hand)." },
  "accessory-right":  { label: "Right Accessory",  zIndex: 11, allowedTypes: ["accessory"],                      description: "Ring, bracelet (right hand)." },
  "accessory-neck":   { label: "Necklace",         zIndex: 12, allowedTypes: ["accessory"],                      description: "Necklace, scarf, collar." },
  "badge":            { label: "Badge",             zIndex: 13, allowedTypes: ["badge"],                          description: "ID badges and visitor passes." }
}>>


/* ----------------------------------------------------------------
   ITEMS  ($ITEMS)
   Every obtainable object in the game. Availability and equipped
   state are tracked in $gs.inventory — never here.

   Shape:
   {
     name:        string         Display name
     description: string         Flavour text shown in tooltip and inspect view
     category:    string         "apparel" | "tool" | "key" | "document" | "cosmetic"
     type:        string         Subcategory used for slot compatibility checks
     slot:        string | null  Slot key from $SLOTS; null for non-apparel
     zIndex:      int | null     Canvas layer order; null for non-apparel
     image:       string | null  Filename only — no path prefix (e.g. "blazer-navy.png")
                                 Icon path:  images/items/<image>
                                 Layer path: images/items/layers/<image>
                                 null if no art yet
     tags:        string[]       Arbitrary tags for filtering and conditional logic
     value:       int            Worth in cents (0 = no monetary value)
     consumable:  bool           true = removed from inventory after use
                                 false = persists after use (default: false)
     effects:     object | null  Stat deltas applied on use (Category A items only)
                                 Keys must match keys in $gs.stats
                                 null = no automatic effect; use passage routing instead
                                 Example: { stamina: 15, stress: -8 }
   }

   Items with a passage named Use::<key> in the story are Category B items.
   Their use action navigates to that passage in sector-3.
   Items without such a passage and with non-null effects are Category A.
   Items with neither are non-functional (inspect only).
   See AUTHORING.md for the full use routing decision tree.
---------------------------------------------------------------- */
<<set $ITEMS = {

  /* -- UNDERWEAR ------------------------------------------------ */
  "plain-bra-white": {
    name: "White Cotton Bra", description: "Unremarkable. The kind you forget is there.",
    category: "apparel", type: "underwear-top", slot: "underwear-top", zIndex: 1,
    image: "test.png", tags: ["underwear","basic","white"], value: 800,
    consumable: false, effects: null
  },
  "plain-bra-black": {
    name: "Black Cotton Bra", description: "Slightly less unremarkable.",
    category: "apparel", type: "underwear-top", slot: "underwear-top", zIndex: 1,
    image: "test.png", tags: ["underwear","basic","black"], value: 800,
    consumable: false, effects: null
  },
  "plain-underwear-white": {
    name: "White Cotton Underwear", description: "Standard issue. Comfortable.",
    category: "apparel", type: "underwear-bottom", slot: "underwear-bottom", zIndex: 2,
    image: "test.png", tags: ["underwear","basic","white"], value: 600,
    consumable: false, effects: null
  },

  /* -- LEGWEAR -------------------------------------------------- */
  "sheer-tights-nude": {
    name: "Nude Sheer Tights", description: "Nearly invisible. Office-appropriate.",
    category: "apparel", type: "legwear", slot: "legwear", zIndex: 3,
    image: "test.png", tags: ["legwear","sheer","nude","office"], value: 600,
    consumable: false, effects: null
  },
  "sheer-tights-black": {
    name: "Black Sheer Tights", description: "Thin enough for the season, dark enough to mean business.",
    category: "apparel", type: "legwear", slot: "legwear", zIndex: 3,
    image: "test.png", tags: ["legwear","sheer","black","office"], value: 600,
    consumable: false, effects: null
  },

  /* -- BOTTOMS -------------------------------------------------- */
  "pencil-skirt-navy": {
    name: "Navy Pencil Skirt", description: "Knee-length. Structured. Meets dress code without effort.",
    category: "apparel", type: "bottom", slot: "bottom", zIndex: 4,
    image: "test.png", tags: ["skirt","navy","office","formal"], value: 4500,
    consumable: false, effects: null
  },
  "trousers-charcoal": {
    name: "Charcoal Trousers", description: "High-waisted, tapered. Practically a uniform.",
    category: "apparel", type: "bottom", slot: "bottom", zIndex: 4,
    image: "test.png", tags: ["trousers","charcoal","office","formal"], value: 5200,
    consumable: false, effects: null
  },

  /* -- TOPS ----------------------------------------------------- */
  "blouse-white-button": {
    name: "White Button Blouse", description: "Crisp. Pressed. Exactly what is expected.",
    category: "apparel", type: "top", slot: "top", zIndex: 5,
    image: "test.png", tags: ["blouse","white","office","formal"], value: 3800,
    consumable: false, effects: null
  },
  "blouse-ivory-silk": {
    name: "Ivory Silk Blouse", description: "Slightly too nice for this job. You wear it anyway.",
    category: "apparel", type: "top", slot: "top", zIndex: 5,
    image: "test.png", tags: ["blouse","ivory","silk","elegant"], value: 7200,
    consumable: false, effects: null
  },

  /* -- OUTERWEAR ------------------------------------------------ */
  "blazer-navy": {
