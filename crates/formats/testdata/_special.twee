    consumable: false, effects: null
  },

  /* -- SHOES ---------------------------------------------------- */
  "heels-black-low": {
    name: "Black Low Heels", description: "Two inches. The acceptable limit.",
    category: "apparel", type: "shoes", slot: "shoes", zIndex: 7,
