::StoryInit
<<set $gs = {
    /* player stats — note the >> inside the comment should not break macro parsing */
    health: 100,
    /* inventory — <<link>> ref inside comment */
    inventory: {
        /* equipped items */
        equipped: "sword"
    },
    /* flags — using <<set>> style references inside comments */
    flags: {
        met_king: false,
        /* more flags go here */
        has_map: true
    }
}>>
