/target
node_modules/
out/
*.vsix
.vscode/
*.swp
*.swo
*~
.DS_Store

# Bundled server binaries (built by build.sh release/package)
extensions/vscode/bin/knot-server
extensions/vscode/bin/knot-server.exe

# Preserve the .gitkeep placeholder
