{
  "name": "knot",
  "displayName": "Knot — Twine Language Support",
  "description": "Language server for Twine development with multi-format support: diagnostics, completions, go-to-definition, rename, type inference, and Tweego build integration.",
  "version": "2.0.0",
  "publisher": "Stormbyte",
  "keywords": [
    "twine",
    "twee",
    "sugarcube",
    "harlowe",
    "chapbook",
    "interactive fiction",
    "visual novel",
    "if",
    "interactive narrative",
    "tweego",
    "language server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/StormByte0/Knot"
  },
  "bugs": {
    "url": "https://github.com/StormByte0/Knot/issues"
  },
  "homepage": "https://stormbyte0.github.io/Knot/",
  "icon": "assets/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "galleryBanner": {
    "color": "#1a1e2e",
    "theme": "dark"
  },
  "main": "./client/out/extension.js",
  "activationEvents": [
    "workspaceContains:**/*.tw",
    "workspaceContains:**/*.twee"
  ],
  "contributes": {
    "commands": [
      {
        "command": "knot.showOutput",
        "title": "Knot: Show Language Server Output"
      },
      {
        "command": "knot.restart",
        "title": "Knot: Restart Language Server"
      },
      {
        "command": "knot.refreshDocuments",
        "title": "Knot: Refresh All Documents"
      },
      {
        "command": "knot.goToPassage",
        "title": "Knot: Go to Passage"
      },
      {
        "command": "knot.openSettings",
        "title": "Knot: Open Settings"
      },
      {
        "command": "knot.verifyTweego",
        "title": "Knot: Verify Tweego Installation"
      },
      {
        "command": "knot.listFormats",
        "title": "Knot: List Available Story Formats"
      },
      {
        "command": "knot.selectFormat",
        "title": "Knot: Select Story Format"
      },
      {
        "command": "knot.build",
        "title": "Knot: Build"
      },
      {
        "command": "knot.buildTest",
        "title": "Knot: Build (Test Mode)"
      },
      {
        "command": "knot.startWatch",
        "title": "Knot: Start Watch Mode"
      },
      {
        "command": "knot.stopWatch",
        "title": "Knot: Stop Watch Mode"
      },
      {
        "command": "knot.mainMenu",
        "title": "Knot: Open Menu"
      },
      {
        "command": "knot.showStatus",
        "title": "Knot: Show Status"
      }
    ],
    "keybindings": [
      {
        "command": "knot.goToPassage",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorLangId == twine || resourceExtname == .tw || resourceExtname == .twee"
      },
      {
        "command": "knot.build",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorLangId == twine || resourceExtname == .tw || resourceExtname == .twee"
      },
      {
        "command": "knot.selectFormat",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorLangId == twine || resourceExtname == .tw || resourceExtname == .twee"
      }
    ],
    "languages": [
      {
        "id": "twine",
        "aliases": [
          "Twine",
          "Twee"
        ],
        "extensions": [
          ".tw",
          ".twee"
        ],
        "filenames": [],
        "filenamePatterns": [
          "_*.twee",
          "_*.tw"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "twine",
        "scopeName": "source.twee",
        "path": "./syntaxes/twee.tmLanguage.json"
      },
      {
        "scopeName": "source.twee.embedded",
        "path": "./syntaxes/twee-script.tmLanguage.json",
        "injectTo": [
          "source.twee"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "javascript",
          "meta.embedded.block.css": "css"
        }
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "twine",
        "scopes": {
          "function": [
            "entity.name.function.macro.twee"
          ],
          "class": [
            "entity.name.section.passage.twee"
          ],
          "variable": [
            "variable.other.story.twee"
          ],
          "operator": [
            "keyword.operator.twee"
          ],
          "string": [
            "string.quoted.double.twee"
          ],
          "number": [
            "constant.numeric.twee"
          ],
          "comment": [
            "comment.block.twee"
          ],
          "enumMember": [
            "string.other.link.twee"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Knot",
      "properties": {
        "knot.format.activeFormat": {
          "type": "string",
          "default": "",
          "markdownDescription": "Story format ID to use for language features. When empty, Knot auto-detects from `StoryData`. Supported: `sugarcube-2`, `harlowe-3`, `chapbook-1`, or any installed format."
        },
        "knot.format.formatsDirectory": {
          "type": "string",
          "default": ".storyformats",
          "markdownDescription": "Directory containing story format packages. Each subdirectory should contain a `format.js` or equivalent format definition."
        },
        "knot.tweego.path": {
          "type": "string",
          "default": "tweego",
          "markdownDescription": "Path to the Tweego executable. Can be an absolute path or a command name available on `$PATH`."
        },
        "knot.tweego.outputFile": {
          "type": "string",
          "default": "dist/index.html",
          "markdownDescription": "Output file path for the compiled HTML file, relative to the workspace root."
        },
        "knot.tweego.formatOverride": {
          "type": "string",
          "default": "",
          "markdownDescription": "Story format ID to pass to Tweego, overriding the format declared in `StoryData`. Leave empty to use the detected format."
        },
        "knot.tweego.modulePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Module directories (`-m`) to include when building. Paths are relative to the workspace root."
        },
        "knot.tweego.headFile": {
          "type": "string",
          "default": "",
          "markdownDescription": "File whose contents are appended verbatim to the `<head>` of the compiled HTML."
        },
        "knot.tweego.noTrim": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Disable whitespace trimming in the compiled output."
        },
        "knot.tweego.logFiles": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Log all processed input files to the output channel."
        },
        "knot.tweego.extraArgs": {
          "type": "string",
          "default": "",
          "markdownDescription": "Extra arguments appended verbatim to the Tweego command line."
        },
        "knot.project.storyFilesDirectory": {
          "type": "string",
          "default": "src",
          "markdownDescription": "Directory containing `.tw`/`.twee` source files, relative to the workspace root."
        },
        "knot.project.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Additional directories to include in workspace indexing. Glob patterns are supported."
        },
        "knot.project.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Glob patterns to exclude from workspace indexing."
        },
        "knot.lint.unknownPassage": {
          "type": "string",
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for unknown passage link targets."
        },
        "knot.lint.unknownMacro": {
          "type": "string",
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for unknown macro names."
        },
        "knot.lint.duplicatePassage": {
          "type": "string",
          "default": "error",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for duplicate passage names."
        },
        "knot.lint.typeMismatch": {
          "type": "string",
          "default": "error",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for type mismatch in comparisons."
        },
        "knot.lint.unreachablePassage": {
          "type": "string",
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for passages unreachable from start."
        },
        "knot.lint.containerStructure": {
          "type": "string",
          "default": "error",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for structural errors (e.g., else outside if)."
        },
        "knot.lint.deprecatedMacro": {
          "type": "string",
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for deprecated macro usage."
        },
        "knot.lint.missingArgument": {
          "type": "string",
          "default": "warning",
          "enum": [
            "error",
            "warning",
            "info",
            "off"
          ],
          "description": "Severity for missing required macro arguments."
        },
        "knot.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "description": "Log level for the Knot output channel. Use 'debug' or 'trace' to diagnose issues."
        }
      }
    }
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "build": "npm --prefix client run build && npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "build:server": "npm --prefix server run build",
    "test": "npm --prefix server test",
    "test:compile": "npm --prefix server run pretest",
    "package:vsix": "npm run build && npx @vscode/vsce package",
    "watch:client": "npm --prefix client run watch",
    "watch:server": "npm --prefix server run watch",
    "watch": "npx concurrently \"npm run watch:client\" \"npm run watch:server\""
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.5"
  }
}
