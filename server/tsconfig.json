{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "out/src",
    "rootDir": "src",
    "baseUrl": ".",
    "lib": ["ES2022"],
    "paths": {
      "@core/*": ["src/core/*"],
      "@handlers/*": ["src/handlers/*"],
      "@hooks/*": ["src/hooks/*"],
      "@formats/*": ["src/formats/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out"]
}
