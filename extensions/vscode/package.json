    "semanticTokenScopes": [
      {
        "_comment": "All five language IDs use identical scopes so that semantic tokens render with the same colors regardless of which language ID is active. This prevents visual inconsistency when the formatDetected notification switches language IDs after workspace indexing. Format-specific TextMate grammars handle syntax pattern differences independently.",
        "language": "twee",
        "scopes": {
          "passageHeader": [
            "entity.name.section.passage.twee"
          ],
          "passageName": [
            "entity.name.passage.twee"
          ],
          "specialPassageHeader": [
            "punctuation.definition.passage.special.twee"
          ],
          "specialPassage": [
            "entity.name.section.special-passage.twee",
            "markup.bold.entity.name.section.twee"
          ],
          "link": [
            "markup.underline.link.passage.twee"
          ],
          "macro": [
            "support.function.macro.twee"
          ],
          "function": [
            "entity.name.function",
            "entity.name.function.widget.twee"
          ],
          "variable": [
            "variable.other.readwrite",
            "variable.other.readwrite.twee"
          ],
          "string": [
            "string",
            "string.unquoted.twee"
          ],
          "number": [
            "constant.numeric",
            "constant.numeric.twee"
          ],
          "comment": [
            "comment",
            "comment.block.twee"
          ],
          "operator": [
            "keyword.operator",
            "keyword.operator.assignment.twee"
          ],
          "namespace": [
            "support.class",
            "support.constant.global-object.twee"
          ],
          "property": [
            "variable.other.property",
            "variable.other.property.twee"
          ],
          "tag": [
            "meta.decorator.tag.twee",
            "entity.other.attribute-name.twee"
          ],
          "keyword": [
            "keyword.control",
            "keyword.control.twee"
          ],
          "boolean": [
            "constant.language.boolean",
            "constant.language.boolean.twee"
          ],
          "passageRef": [
            "support.function.passage-ref.twee",
            "string.interpolated.passage-ref.twee"
          ],
          "prose": [
            "markup.prose.twee",
            "string.other.prose.twee"
          ],
          "inlineStyle": [
            "entity.other.attribute-name.class.twee"
          ],
          "textFormat": [
            "markup.bold.twee",
            "markup.italic.twee"
          ],
          "macroDelimiter": [
            "punctuation.definition.tag",
            "meta.brace.angle"
          ],
          "macroDelimiter.blockDepth1": [
            "keyword.operator"
          ],
          "macroDelimiter.blockDepth2": [
            "entity.name.function"
          ],
          "macroDelimiter.blockDepth3": [
            "string"
          ],
          "macroDelimiter.blockDepth4": [
            "entity.name.type"
          ],
          "macroDelimiter.blockDepth5": [
            "variable.other"
          ],
          "macroDelimiter.blockDepth6": [
            "constant.numeric"
          ],
          "heading": [
            "markup.heading.twee"
          ],
          "horizontalRule": [
            "punctuation.separator.hr.twee"
          ],
          "listMarker": [
            "punctuation.definition.list.twee"
          ],
          "blockquote": [
            "punctuation.definition.quote.twee"
          ],
          "blockquoteBlock": [
            "punctuation.definition.quote.twee"
          ],
          "table": [
            "punctuation.definition.table.twee"
          ],
          "codeBlock": [
            "markup.raw.code.twee"
          ],
          "inlineCode": [
            "markup.raw.inline.twee"
          ]
        }
      },
      {
        "language": "twee-sugarcube",
        "scopes": {
          "passageHeader": [
            "entity.name.section.passage.twee"
          ],
          "passageName": [
            "entity.name.passage.twee"
          ],
          "specialPassageHeader": [
            "punctuation.definition.passage.special.twee"
          ],
          "specialPassage": [
            "entity.name.section.special-passage.twee",
            "markup.bold.entity.name.section.twee"
          ],
          "link": [
            "markup.underline.link.passage.twee"
          ],
          "macro": [
            "support.function.macro.twee"
          ],
          "function": [
            "entity.name.function",
            "entity.name.function.widget.twee"
          ],
          "variable": [
            "variable.other.readwrite",
            "variable.other.readwrite.twee"
          ],
          "string": [
            "string",
            "string.unquoted.twee"
          ],
          "number": [
            "constant.numeric",
            "constant.numeric.twee"
          ],
          "comment": [
            "comment",
            "comment.block.twee"
          ],
          "operator": [
            "keyword.operator",
            "keyword.operator.assignment.twee"
          ],
          "namespace": [
            "support.class",
            "support.constant.global-object.twee"
          ],
          "property": [
            "variable.other.property",
            "variable.other.property.twee"
          ],
          "tag": [
            "meta.decorator.tag.twee",
            "entity.other.attribute-name.twee"
          ],
          "keyword": [
            "keyword.control",
            "keyword.control.twee"
          ],
          "boolean": [
            "constant.language.boolean",
            "constant.language.boolean.twee"
          ],
          "passageRef": [
            "support.function.passage-ref.twee",
            "string.interpolated.passage-ref.twee"
          ],
          "prose": [
            "markup.prose.twee",
            "string.other.prose.twee"
          ],
          "inlineStyle": [
