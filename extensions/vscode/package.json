{
  "name": "knot",
  "displayName": "Knot \u2014 Twine IDE",
  "description": "Next-generation IDE for Twine and Twee projects",
  "version": "2.0.0",
  "publisher": "stormbyte",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers"
  ],
  "keywords": [
    "twine",
    "twee",
    "sugarcube",
    "harlowe",
    "interactive fiction"
  ],
  "activationEvents": [
    "onLanguage:twee",
    "workspaceContains:**/*.tw",
    "workspaceContains:**/*.twee"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "twee",
        "extensions": [
          ".tw",
          ".twee"
        ],
        "aliases": [
          "Twee",
          "Twine"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "twee-sugarcube",
        "extensions": [],
        "aliases": [
          "Twee (SugarCube)"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "twee-harlowe",
        "extensions": [],
        "aliases": [
          "Twee (Harlowe)"
        ]
      },
      {
        "id": "twee-chapbook",
        "extensions": [],
        "aliases": [
          "Twee (Chapbook)"
        ]
      },
      {
        "id": "twee-snowman",
        "extensions": [],
        "aliases": [
          "Twee (Snowman)"
        ]
      }
    ],
    "grammars": [
      {
        "language": "twee",
        "scopeName": "source.twee",
        "path": "./syntaxes/twee.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript",
          "source.css.embedded.twee": "css",
          "text.html.embedded.twee": "html"
        }
      },
      {
        "language": "twee-sugarcube",
        "scopeName": "source.sugarcube.twee",
        "path": "./syntaxes/sugarcube.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript",
          "source.css.embedded.twee": "css",
          "text.html.embedded.twee": "html"
        }
      },
      {
        "language": "twee-harlowe",
        "scopeName": "source.harlowe.twee",
        "path": "./syntaxes/harlowe.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript",
          "source.css.embedded.twee": "css"
        }
      },
      {
        "language": "twee-chapbook",
        "scopeName": "source.chapbook.twee",
        "path": "./syntaxes/chapbook.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript"
        }
      },
      {
        "language": "twee-snowman",
        "scopeName": "source.snowman.twee",
        "path": "./syntaxes/snowman.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript"
        }
      }
    ],
    "commands": [
      {
        "command": "knot.openStoryMap",
        "title": "Knot: Open Story Map",
        "category": "Knot",
        "icon": "$(graph)"
      },
      {
        "command": "knot.build",
        "title": "Knot: Build Project",
        "category": "Knot"
      },
      {
        "command": "knot.play",
        "title": "Knot: Play Story",
        "category": "Knot"
      },
      {
        "command": "knot.restartServer",
        "title": "Knot: Restart Language Server",
        "category": "Knot"
      },
      {
        "command": "knot.reindexWorkspace",
        "title": "Knot: Re-index Workspace",
        "category": "Knot"
      },
      {
        "command": "knot.detectCompiler",
        "title": "Knot: Detect Compiler",
        "category": "Knot"
      },
      {
        "command": "knot.openPassageByName",
        "title": "Knot: Open Passage by Name",
        "category": "Knot"
      },
      {
        "command": "knot.toggleAutoRebuild",
        "title": "Knot: Toggle Auto-Rebuild in Play Mode",
        "category": "Knot"
      },
      {
        "command": "knot.playFromPassage",
        "title": "Knot: Play from This Passage",
        "category": "Knot",
        "icon": "$(play)"
      },
      {
        "command": "knot.initProject",
        "title": "Knot: Initialize Project",
        "category": "Knot",
        "icon": "$(add)"
      }
    ],
    "keybindings": [
      {
        "command": "knot.play",
        "key": "f5",
        "when": "resourceLangId == twee"
      },
      {
        "command": "knot.playFromPassage",
        "key": "shift+f5",
        "when": "resourceLangId == twee"
      },
      {
        "command": "knot.build",
        "key": "f6",
        "when": "resourceLangId == twee"
      },
      {
        "command": "knot.openStoryMap",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceLangId == twee"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "knot-container",
          "title": "Knot IDE",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "knot-container": [
        {
          "type": "webview",
          "id": "knot.debugView",
          "name": "Passage Diagnostics",
          "icon": "$(bug)",
          "visibility": "visible"
        },
        {
          "type": "webview",
          "id": "knot.variableFlowView",
          "name": "Variable Tracking",
          "icon": "$(symbol-variable)",
          "visibility": "visible"
        },
        {
          "type": "webview",
          "id": "knot.profileView",
          "name": "Workspace Profile",
          "icon": "$(dashboard)",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "knot.playFromPassage",
          "when": "resourceLangId == twee",
          "group": "navigation@10"
        }
      ],
      "editor/title": [
        {
          "command": "knot.openStoryMap",
          "when": "resourceLangId == twee",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Knot",
      "properties": {
        "knot.experimental.rustServer": {
          "type": "boolean",
          "default": true,
          "description": "Use the native Rust language server for analysis. When disabled, falls back to TextMate grammar only."
        },
        "knot.server.path": {
          "type": "string",
          "default": "",
          "description": "Override path to the knot-server binary. Leave empty to use the bundled binary."
        },
        "knot.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace level for the Knot language server communication.",
          "enumDescriptions": [
            "No tracing",
            "Log messages only",
            "Log messages and detailed communication"
          ]
        },
        "knot.diagnostics.broken-link": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "warning",
          "description": "Severity for broken link diagnostics (links to non-existent passages)."
        },
        "knot.diagnostics.unreachable-passage": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "warning",
          "description": "Severity for unreachable passage diagnostics."
        },
        "knot.diagnostics.uninitialized-variable": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "warning",
          "description": "Severity for uninitialized variable diagnostics."
        },
        "knot.diagnostics.unused-variable": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "hint",
          "description": "Severity for unused variable diagnostics."
        },
        "knot.diagnostics.redundant-write": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "hint",
          "description": "Severity for redundant write diagnostics (variable written twice without intervening read)."
        },
        "knot.diagnostics.duplicate-passage-name": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "error",
          "description": "Severity for duplicate passage name diagnostics."
        },
        "knot.diagnostics.empty-passage": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "hint",
          "description": "Severity for empty passage diagnostics."
        },
        "knot.diagnostics.dead-end-passage": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "info",
          "description": "Severity for dead-end passage diagnostics (no outgoing links)."
        },
        "knot.diagnostics.invalid-passage-name": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "warning",
          "description": "Severity for invalid passage name diagnostics."
        },
        "knot.diagnostics.complex-passage": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "hint",
          "description": "Severity for complex passage diagnostics (too many outgoing links)."
        },
        "knot.diagnostics.large-passage": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "hint",
            "off"
          ],
          "default": "hint",
          "description": "Severity for large passage diagnostics (exceeds word count threshold)."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "knot",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "enum": [
              "build",
              "watch"
            ],
            "description": "The Knot task to run."
          }
        }
      }
    ],
    "semanticTokenScopes": [
      {
        "_comment": "All five language IDs use identical scopes so that semantic tokens render with the same colors regardless of which language ID is active. This prevents visual inconsistency when the formatDetected notification switches language IDs after workspace indexing. Format-specific TextMate grammars handle syntax pattern differences independently.",
        "language": "twee",
        "scopes": {
          "passageHeader": [
            "entity.name.section.passage.twee"
          ],
          "passageName": [
            "entity.name.passage.twee"
          ],
          "specialPassageHeader": [
            "punctuation.definition.passage.special.twee"
          ],
          "specialPassage": [
            "entity.name.section.special-passage.twee",
            "markup.bold.entity.name.section.twee"
          ],
          "link": [
            "markup.underline.link.passage.twee"
          ],
          "macro": [
            "support.function.macro.twee"
          ],
          "function": [
            "entity.name.function.widget.twee"
          ],
          "variable": [
            "variable.other.readwrite.twee"
          ],
          "string": [
            "string.unquoted.twee"
          ],
          "number": [
            "constant.numeric.twee"
          ],
          "comment": [
            "comment.block.twee"
          ],
          "operator": [
            "keyword.operator.assignment.twee"
          ],
          "namespace": [
            "support.constant.global-object.twee"
          ],
          "property": [
            "variable.other.property.twee"
          ],
          "tag": [
            "meta.decorator.tag.twee",
            "entity.other.attribute-name.twee"
          ],
          "keyword": [
            "keyword.control.twee"
          ],
          "boolean": [
            "constant.language.boolean.twee"
          ],
          "passageRef": [
            "support.function.passage-ref.twee",
            "string.interpolated.passage-ref.twee"
          ],
          "prose": [
            "markup.prose.twee",
            "string.other.prose.twee"
          ],
          "inlineStyle": [
            "entity.other.attribute-name.class.twee"
          ],
          "textFormat": [
            "markup.bold.twee",
            "markup.italic.twee"
          ]
        }
      },
