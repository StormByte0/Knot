{
  "name": "knot",
  "displayName": "Knot — Twine IDE (Beta)",
  "description": "Next-generation IDE for Twine and Twee projects. Beta — SugarCube 2 is fully supported; other formats are in progress.",
  "version": "2.0.0",
  "publisher": "stormbyte",
  "license": "SEE LICENSE IN LICENSE",
  "licenseUrl": "../LICENSE",
  "preview": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Debuggers"
  ],
  "keywords": [
    "twine",
    "twee",
    "sugarcube",
    "harlowe",
    "interactive fiction",
    "beta"
  ],
  "activationEvents": [
    "workspaceContains:**/*.tw",
    "workspaceContains:**/*.twee"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "twee",
        "extensions": [
          ".tw",
          ".twee"
        ],
        "aliases": [
          "Twee",
          "Twine"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "twee-sugarcube",
        "extensions": [],
        "aliases": [
          "Twee (SugarCube)"
        ],
        "configuration": "./language-configuration-sugarcube.json"
      },
      {
        "id": "twee-harlowe",
        "extensions": [],
        "aliases": [
          "Twee (Harlowe)"
        ],
        "configuration": "./language-configuration-harlowe.json"
      },
      {
        "id": "twee-chapbook",
        "extensions": [],
        "aliases": [
          "Twee (Chapbook)"
        ],
        "configuration": "./language-configuration-chapbook.json"
      },
      {
        "id": "twee-snowman",
        "extensions": [],
        "aliases": [
          "Twee (Snowman)"
        ],
        "configuration": "./language-configuration-snowman.json"
      }
    ],
    "grammars": [
      {
        "language": "twee",
        "scopeName": "source.twee",
        "path": "./syntaxes/twee.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript",
          "source.css.embedded.twee": "css",
          "text.html.embedded.twee": "html"
        }
      },
      {
        "language": "twee-sugarcube",
        "scopeName": "source.sugarcube.twee",
        "path": "./syntaxes/sugarcube.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript",
          "source.css.embedded.twee": "css",
          "text.html.embedded.twee": "html"
        }
      },
      {
        "language": "twee-harlowe",
        "scopeName": "source.harlowe.twee",
        "path": "./syntaxes/harlowe.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript",
          "source.css.embedded.twee": "css"
        }
      },
      {
        "language": "twee-chapbook",
        "scopeName": "source.chapbook.twee",
        "path": "./syntaxes/chapbook.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript"
        }
      },
      {
        "language": "twee-snowman",
        "scopeName": "source.snowman.twee",
        "path": "./syntaxes/snowman.tmLanguage.json",
        "embeddedLanguages": {
          "source.js.embedded.twee": "javascript"
        }
      }
    ],
    "commands": [
      {
        "command": "knot.openStoryMap",
        "title": "Knot: Open Story Map",
        "category": "Knot",
        "icon": "media/knot-icon.svg"
      },
      {
        "command": "knot.build",
        "title": "Knot: Build Project",
        "category": "Knot"
      },
      {
        "command": "knot.play",
        "title": "Knot: Play Story",
        "category": "Knot"
      },
      {
        "command": "knot.restartServer",
        "title": "Knot: Restart Language Server",
        "category": "Knot"
      },
      {
        "command": "knot.openSettings",
        "title": "Knot: Open Extension Settings",
        "category": "Knot"
      },
      {
        "command": "knot.reindexWorkspace",
        "title": "Knot: Re-index Workspace",
        "category": "Knot"
      },
      {
        "command": "knot.detectCompiler",
        "title": "Knot: Detect Compiler",
        "category": "Knot"
      },
      {
        "command": "knot.configureStoryFormats",
        "title": "Knot: Configure Story Formats",
        "category": "Knot"
      },
      {
        "command": "knot.openManagedStorage",
        "title": "Knot: Open Managed Storage Folder",
        "category": "Knot"
      },
      {
        "command": "knot.openPassageByName",
        "title": "Knot: Open Passage by Name",
        "category": "Knot"
      },
      {
        "command": "knot.toggleWatch",
        "title": "Knot: Toggle Watch (Auto-Rebuild on Save)",
        "category": "Knot"
      },
      {
        "command": "knot.playFromPassage",
        "title": "Knot: Play from This Passage",
        "category": "Knot",
        "icon": "$(play)"
      },
      {
        "command": "knot.initProject",
        "title": "Knot: Initialize Project",
        "category": "Knot",
        "icon": "$(add)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "knot-container",
          "title": "Knot IDE",
          "icon": "media/knot-icon.svg"
        }
      ]
    },
    "views": {
      "knot-container": [
        {
          "type": "webview",
          "id": "knot.debugView",
          "name": "Passage Diagnostics",
          "icon": "$(bug)",
          "visibility": "visible"
        },
        {
          "type": "webview",
          "id": "knot.variableFlowView",
          "name": "Variable Tracking",
          "icon": "$(symbol-variable)",
          "visibility": "visible"
        },
        {
          "type": "webview",
          "id": "knot.profileView",
          "name": "Project Info",
          "icon": "$(dashboard)",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "knot.playFromPassage",
          "when": "resourceLangId =~ /twee/",
          "group": "navigation@10"
        }
      ],
      "editor/title": [
        {
          "command": "knot.openStoryMap",
          "when": "resourceLangId =~ /twee/",
          "group": "navigation"
        }
      ]
    },
    "configuration": [
      {
        "title": "Build",
        "properties": {
          "knot.build.outputDir": {
            "type": "string",
            "default": "build",
            "description": "Where the compiled HTML is written. Relative paths are resolved against the workspace root. RECOMMENDED LAYOUT: set knot.build.sourceDir to 'src' and leave this as 'build' — the workspace then contains src/ (your .twee files) and build/ (the output), and Tweego won't scan build/ as input. If you keep source files at the workspace root, set this to a path OUTSIDE the workspace (e.g. '../build') to avoid 'Output file cannot be an input source' errors.",
            "scope": "workspace"
          },
          "knot.build.sourceDir": {
            "type": "string",
            "default": "",
            "description": "Subdirectory (relative to workspace root) containing .twee/.js/.css source files. RECOMMENDED: set to 'src' so the workspace can contain a build/ output folder without Tweego scanning it as input. When empty, the workspace root is used as the source — in that case, set knot.build.outputDir to a path OUTSIDE the workspace to avoid 'Output file cannot be an input source' errors.",
            "scope": "workspace"
          },
          "knot.build.tweegoPath": {
            "type": "string",
            "default": "",
            "description": "Tweego compiler binary to use. Leave empty for auto-resolution (managed download → PATH). Use 'Knot: Configure Build Toolchain' to download or browse.",
            "scope": "workspace"
          },
          "knot.build.storyformatsPath": {
            "type": "string",
            "default": "",
            "description": "Folder containing installed story formats (each subdirectory needs a format.js). Leave empty to use the extension-managed folder. Prefer 'Knot: Configure Story Formats' to browse.",
            "scope": "workspace"
          },
          "knot.build.flags": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Additional command-line flags to pass to Tweego on every build (e.g. [\"--no-trim\", \"--twee2-compat\"]). Merged with flags from .vscode/knot.json. See Tweego docs for available flags.",
            "scope": "workspace"
          }
        },
        "order": 0
      },
      {
        "title": "Diagnostics",
        "properties": {
          "knot.diagnostics.broken-link": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "warning",
            "description": "Links pointing to a non-existent passage.",
            "scope": "workspace"
          },
          "knot.diagnostics.unreachable-passage": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "warning",
            "description": "Passages that no link ever reaches.",
            "scope": "workspace"
          },
          "knot.diagnostics.uninitialized-variable": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "warning",
            "description": "Variable read before being assigned a value.",
            "scope": "workspace"
          },
          "knot.diagnostics.unused-variable": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "hint",
            "description": "Variable declared but never read.",
            "scope": "workspace"
          },
          "knot.diagnostics.redundant-write": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "hint",
            "description": "Variable written twice with no read in between.",
            "scope": "workspace"
          },
          "knot.diagnostics.duplicate-passage-name": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "error",
            "description": "Two or more passages share the same name (builds will fail).",
            "scope": "workspace"
          },
          "knot.diagnostics.empty-passage": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "hint",
            "description": "Passage with no body content.",
            "scope": "workspace"
          },
          "knot.diagnostics.dead-end-passage": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "info",
            "description": "Passage with no outgoing links (player cannot leave).",
            "scope": "workspace"
          },
          "knot.diagnostics.invalid-passage-name": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "warning",
            "description": "Passage name contains characters that may break links.",
            "scope": "workspace"
          },
          "knot.diagnostics.complex-passage": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "hint",
            "description": "Passage has too many outgoing links (default threshold: 6). Consider splitting.",
            "scope": "workspace"
          },
          "knot.diagnostics.large-passage": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint", "off"],
            "default": "hint",
            "description": "Passage exceeds the recommended word count (default threshold: 500 words). Consider splitting.",
            "scope": "workspace"
          }
        },
        "order": 2
      },
      {
        "title": "Indexing",
        "properties": {
          "knot.indexing.maxFiles": {
            "type": "number",
            "default": 1000,
            "minimum": 1,
            "description": "Maximum number of .tw/.twee/.js files to index. If the workspace exceeds this limit, indexing stops with a warning — prevents the server from hanging on very large workspaces.",
            "scope": "workspace"
          }
        },
        "order": 3
      },
      {
        "title": "Status & Paths",
        "properties": {
          "knot.managed.storagePath": {
            "type": "string",
            "default": "",
            "description": "Read-only — the extension's managed storage directory where the Tweego binary and story format cache are downloaded. Updated automatically on startup.",
            "scope": "machine-overridable",
            "readOnly": true
          },
          "knot.managed.tweegoPath": {
            "type": "string",
            "default": "",
            "description": "Read-only — path to the Tweego binary Knot downloaded for you. To use your own binary instead, set 'Build: Tweego Path'.",
            "scope": "machine-overridable",
            "readOnly": true
          },
          "knot.managed.storyformatsPath": {
            "type": "string",
            "default": "",
            "description": "Read-only — path to the extension-managed story formats cache (versioned per format). To use your own folder instead, set 'Build: Story Formats Path'.",
            "scope": "machine-overridable",
            "readOnly": true
          },
          "knot.resolved.tweegoPath": {
            "type": "string",
            "default": "",
            "description": "Read-only — the actual Tweego binary that will be used for the next build, after resolving 'Build: Tweego Path' → managed download → PATH. Empty if no Tweego is available.",
            "scope": "machine-overridable",
            "readOnly": true
          }
        },
        "order": 4
      },
      {
        "title": "Advanced",
        "properties": {
          "knot.server.path": {
            "type": "string",
            "default": "",
            "description": "Override path to the knot-server binary. Leave empty to use the bundled binary — only set this when debugging a local server build.",
            "scope": "machine"
          },
          "knot.trace.server": {
            "type": "string",
            "enum": ["off", "messages", "verbose"],
            "default": "off",
            "description": "Trace level for language server communication. Set to 'verbose' when debugging LSP issues, then check the 'Knot' output channel.",
            "enumDescriptions": [
              "No tracing",
              "Log messages only",
              "Log messages and detailed communication"
            ],
            "scope": "window"
          }
        },
        "order": 5
      }
    ],
    "themes": [
      {
        "label": "Knot Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/knot-dark.json"
      },
      {
        "label": "Knot Dark \u2014 Tokens Only",
        "uiTheme": "vs-dark",
        "path": "./themes/knot-dark-tokens.json"
      },
      {
        "label": "Knot Light",
        "uiTheme": "vs",
        "path": "./themes/knot-light.json"
      },
      {
        "label": "Knot Light \u2014 Tokens Only",
        "uiTheme": "vs",
        "path": "./themes/knot-light-tokens.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "knot",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "enum": [
              "build",
              "watch"
            ],
            "description": "The Knot task to run."
          }
        }
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "passageHeader",
        "description": "Twee passage header line (:: Name [tags])"
      },
      {
        "id": "passageName",
        "description": "Passage name in a header"
      },
      {
        "id": "link",
        "description": "Link target in [[...]] syntax"
      },
      {
        "id": "passageRef",
        "description": "Passage reference in macro args"
      },
      {
        "id": "specialPassageHeader",
        "description": "Special passage header (StoryData, StoryInit, etc.)"
      },
      {
        "id": "specialPassage",
        "description": "Special passage name"
      },
      {
        "id": "tag",
        "description": "Passage tag in [tags] syntax"
      },
      {
        "id": "prose",
        "description": "Narrative prose text (story content)"
      },
      {
        "id": "inlineStyle",
        "description": "SugarCube inline style markup (@@.class;text@@)"
      },
      {
        "id": "textFormat",
        "description": "SugarCube text formatting markup (//italic//, ''bold'', __underline__, ==strike==, ~~sub~~, ^^super^^)"
      },
      {
        "id": "macroDelimiter",
        "description": "Macro delimiters (<<, >>, <</)"
      },
      {
        "id": "heading",
        "description": "Heading markup (! Heading)"
      },
      {
        "id": "horizontalRule",
        "description": "Horizontal rule (----)"
      },
      {
        "id": "listMarker",
        "description": "List marker (*, #)"
      },
      {
        "id": "blockquote",
        "description": "Blockquote marker (>)"
      },
      {
        "id": "blockquoteBlock",
        "description": "Blockquote block content"
      },
      {
        "id": "table",
        "description": "Table cell content"
      },
      {
        "id": "codeBlock",
        "description": "Block code ({{{...}}})"
      },
      {
        "id": "inlineCode",
        "description": "Inline code ({{{...}}})"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "definition",
        "description": "Variable is being defined (written to)"
      },
      {
        "id": "controlFlow",
        "description": "Control flow context (silent expressions, etc.)"
      },
      {
        "id": "blockDepth1",
        "description": "Macro at block nesting depth 1"
      },
      {
        "id": "blockDepth2",
        "description": "Macro at block nesting depth 2"
      },
      {
        "id": "blockDepth3",
        "description": "Macro at block nesting depth 3"
      },
      {
        "id": "blockDepth4",
        "description": "Macro at block nesting depth 4"
      },
      {
        "id": "blockDepth5",
        "description": "Macro at block nesting depth 5"
      },
      {
        "id": "blockDepth6",
        "description": "Macro at block nesting depth 6"
      },
      {
        "id": "bold",
        "description": "Bold text formatting markup"
      },
      {
        "id": "underline",
        "description": "Underline text formatting markup"
      },
      {
        "id": "strikethrough",
        "description": "Strikethrough text formatting markup"
      },
      {
        "id": "subscript",
        "description": "Subscript text formatting markup"
      },
      {
