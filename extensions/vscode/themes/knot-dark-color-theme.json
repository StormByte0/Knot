{
  "name": "Knot Dark",
  "$schema": "vscode://schemas/color-theme",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#c0caf5",
    "editor.lineHighlightBackground": "#1f2335",
    "editor.selectionBackground": "#33467c",
    "editorCursor.foreground": "#c0caf5",
    "editorWhitespace.foreground": "#3b4261",
    "editorIndentGuide.background": "#3b4261",
    "editorIndentGuide.activeBackground": "#565f89",
    "editor.selectionHighlightBackground": "#33467c55",
    "editor.wordHighlightBackground": "#33467c55",
    "editor.wordHighlightStrongBackground": "#9d7cd855",
    "editorBracketHighlight.foreground1": "#7aa2f7",
    "editorBracketHighlight.foreground2": "#e0af68",
    "editorBracketHighlight.foreground3": "#9ece6a",
    "editorBracketHighlight.foreground4": "#bb9af7",
    "editorBracketHighlight.foreground5": "#f7768e",
    "editorBracketHighlight.foreground6": "#7dcfff",
    "editorBracketHighlight.unexpectedBracket.foreground": "#ff9e64",
    "editorBracketMatch.background": "#33467c55",
    "editorBracketMatch.border": "#7aa2f788"
  },

  "tokenColors": [
    {
      "comment": "=== Passage headers (TextMate — structure) ===",
      "scope": "entity.name.function.passage.twee",
      "settings": { "foreground": "#7aa2f7", "fontStyle": "bold" }
    },
    {
      "scope": "entity.name.passage.twee",
      "settings": { "foreground": "#e0af68" }
    },
    {
      "scope": ["entity.name.passage.special.twee", "entity.name.passage.special.sugarcube"],
      "settings": { "foreground": "#bb9af7", "fontStyle": "bold" }
    },
    {
      "scope": ["entity.other.attribute-name.tag.sugarcube", "entity.other.attribute-name.tag.twee"],
      "settings": { "foreground": "#73daca" }
    },
    {
      "scope": ["meta.passage.metadata.twee", "meta.tag.twee"],
      "settings": { "foreground": "#565f89" }
    },

    {
      "comment": "=== Links (TextMate — region detection) ===",
      "scope": ["markup.underline.link.target.twee", "markup.underline.link.passage.twee", "markup.underline.link.passageref.twee"],
      "settings": { "foreground": "#73daca", "fontStyle": "underline" }
    },
    {
      "scope": "string.other.link.display.twee",
      "settings": { "foreground": "#9ece6a" }
    },
    {
      "scope": ["punctuation.definition.link.begin.twee", "punctuation.definition.link.end.twee", "punctuation.separator.link.arrow.twee", "punctuation.separator.link.pipe.twee"],
      "settings": { "foreground": "#565f89" }
    },

    {
      "comment": "=== Macro delimiters (TextMate — << >> are not covered by semantic tokens) ===",
      "scope": ["punctuation.definition.macro.begin.sugarcube", "punctuation.definition.macro.end.sugarcube", "punctuation.definition.macro.begin.twee", "punctuation.definition.macro.end.twee"],
      "settings": { "foreground": "#565f89" }
    },
    {
      "comment": "=== Macro names — fallback (semantic tokens override after indexing) ===",
      "scope": ["keyword.control.macro.sugarcube", "keyword.control.macro.twee"],
      "settings": { "foreground": "#7aa2f7" }
    },
    {
      "scope": ["variable.parameter.sugarcube", "variable.parameter.macro.sugarcube"],
      "settings": { "foreground": "#ff9e64" }
    },

    {
      "comment": "=== Comments (TextMate — region detection) ===",
      "scope": ["comment.block.twee", "comment.block.twine", "comment.block.html"],
      "settings": { "foreground": "#565f89", "fontStyle": "italic" }
    },
    {
      "scope": ["punctuation.definition.comment.twee", "punctuation.definition.comment.twine", "punctuation.definition.comment.html"],
      "settings": { "foreground": "#565f89" }
    },

    {
      "comment": "=== HTML attributes (TextMate — base grammar) ===",
      "scope": "entity.other.attribute-name.html.twee",
      "settings": { "foreground": "#73daca" }
    },
    {
      "scope": "punctuation.separator.key-value.html.twee",
      "settings": { "foreground": "#565f89" }
    },
    {
      "scope": "string.quoted.html.twee",
      "settings": { "foreground": "#9ece6a" }
    },

    {
      "comment": "=== Generic fallbacks (for non-LSP contexts / pre-index window) ===",
      "scope": "entity.name.function",
      "settings": { "foreground": "#7aa2f7" }
    },
    {
      "scope": "keyword.control",
      "settings": { "foreground": "#7aa2f7" }
    },
    {
      "scope": "variable.language",
      "settings": { "foreground": "#f7768e", "fontStyle": "italic" }
    },
    {
      "scope": "support.class",
      "settings": { "foreground": "#7dcfff", "fontStyle": "bold" }
    },
    {
      "scope": "variable.other.property",
      "settings": { "foreground": "#73daca" }
    },
    {
      "scope": "markup.underline.link",
      "settings": { "foreground": "#73daca", "fontStyle": "underline" }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": { "foreground": "#73daca" }
    },
    {
      "scope": "keyword.operator",
      "settings": { "foreground": "#7dcfff" }
    },
    {
      "scope": "constant.numeric",
      "settings": { "foreground": "#ff9e64" }
    },
    {
      "scope": "string",
      "settings": { "foreground": "#9ece6a" }
    },
    {
      "scope": "comment",
      "settings": { "foreground": "#565f89", "fontStyle": "italic" }
    },
    {
      "scope": "constant.language",
      "settings": { "foreground": "#ff9e64" }
    }
  ],

  "semanticTokenColors": {
    "macro": { "foreground": "#7aa2f7" },
    "macro.blockDepth1": { "foreground": "#7aa2f7" },
    "macro.blockDepth2": { "foreground": "#9ece6a" },
    "macro.blockDepth3": { "foreground": "#e0af68" },
    "macro.blockDepth4": { "foreground": "#bb9af7" },
    "macro.blockDepth5": { "foreground": "#f7768e" },
    "macro.blockDepth6": { "foreground": "#7dcfff" },

    "function": { "foreground": "#7aa2f7" },
    "function.blockDepth1": { "foreground": "#7aa2f7" },
    "function.blockDepth2": { "foreground": "#9ece6a" },
    "function.blockDepth3": { "foreground": "#e0af68" },
    "function.blockDepth4": { "foreground": "#bb9af7" },
    "function.blockDepth5": { "foreground": "#f7768e" },
    "function.blockDepth6": { "foreground": "#7dcfff" },

    "variable": { "foreground": "#f7768e", "fontStyle": "italic" },
    "variable.definition": { "foreground": "#f7768e", "fontStyle": "italic bold" },

    "link": { "foreground": "#73daca", "fontStyle": "underline" },

    "operator": { "foreground": "#7dcfff" },
    "string": { "foreground": "#9ece6a" },
    "number": { "foreground": "#ff9e64" },
    "namespace": { "foreground": "#7dcfff", "fontStyle": "bold" },
    "property": { "foreground": "#73daca" },

    "passageHeader": { "foreground": "#7aa2f7", "fontStyle": "bold" },
    "passageName": { "foreground": "#e0af68" },
    "specialPassage": { "foreground": "#bb9af7", "fontStyle": "bold" },
    "tag": { "foreground": "#73daca" },

    "comment": { "foreground": "#565f89", "fontStyle": "italic" },
    "prose": { "foreground": "#c0caf5" },
    "boolean": { "foreground": "#ff9e64" }
  }
}
