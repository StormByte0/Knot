{
  "name": "Knot Light — Tokens Only",
  "$schema": "vscode://schemas/color-theme",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {},
  "tokenColors": [
    {
      "scope": "entity.name.function.passage.twee",
      "settings": {
        "foreground": "#8c5a00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.passage.twee",
      "settings": {
        "foreground": "#8c5a00"
      }
    },
    {
      "scope": [
        "entity.name.passage.special.twee",
        "entity.name.passage.special.sugarcube"
      ],
      "settings": {
        "foreground": "#b85c00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.tag.sugarcube",
        "entity.other.attribute-name.tag.twee"
      ],
      "settings": {
        "foreground": "#0e7490"
      }
    },
    {
      "scope": [
        "meta.passage.metadata.twee",
        "meta.tag.twee"
      ],
      "settings": {
        "foreground": "#5c6a7e"
      }
    },
    {
      "scope": [
        "markup.underline.link.target.twee",
        "markup.underline.link.passage.twee",
        "markup.underline.link.passageref.twee"
      ],
      "settings": {
        "foreground": "#0e7490",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "string.other.link.display.twee",
      "settings": {
        "foreground": "#336f3c"
      }
    },
    {
      "scope": [
        "punctuation.definition.link.begin.twee",
        "punctuation.definition.link.end.twee",
        "punctuation.separator.link.arrow.twee",
        "punctuation.separator.link.pipe.twee"
      ],
      "settings": {
        "foreground": "#5c6a7e"
      }
    },
    {
      "scope": [
        "keyword.control.macro.sugarcube",
        "keyword.control.macro.twee"
      ],
      "settings": {
        "foreground": "#34548a"
      }
    },
    {
      "scope": [
        "variable.parameter.sugarcube",
        "variable.parameter.macro.sugarcube"
      ],
      "settings": {
        "foreground": "#8c4351"
      }
    },
    {
      "scope": [
        "comment.block.twee",
        "comment.block.twine",
        "comment.block.html"
      ],
      "settings": {
        "foreground": "#5c6a7e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.comment.twee",
        "punctuation.definition.comment.twine",
        "punctuation.definition.comment.html"
      ],
      "settings": {
        "foreground": "#5c6a7e"
      }
    },
    {
      "scope": "entity.other.attribute-name.html.twee",
      "settings": {
        "foreground": "#0e7490"
      }
    },
    {
      "scope": "punctuation.separator.key-value.html.twee",
      "settings": {
        "foreground": "#5c6a7e"
      }
    },
    {
      "scope": "string.quoted.html.twee",
      "settings": {
        "foreground": "#336f3c"
      }
    }
  ],
  "semanticTokenColors": {
    "passageHeader": {
      "foreground": "#8c5a00",
      "fontStyle": "bold"
    },
    "passageName": {
      "foreground": "#8c5a00"
    },
    "specialPassageHeader": {
      "foreground": "#b85c00",
      "fontStyle": "bold"
    },
    "specialPassage": {
      "foreground": "#b85c00",
      "fontStyle": "bold"
    },
    "tag": {
      "foreground": "#0e7490"
    },
    "tag.twineCore": {
      "foreground": "#0e7490",
      "fontStyle": "bold"
    },
    "tag.storyFormat": {
      "foreground": "#0e7490",
      "fontStyle": "italic"
    },
    "prose": {
      "foreground": "#343b58"
    },
    "inlineStyle": {
      "foreground": "#0e7490",
      "fontStyle": "italic"
    },
    "textFormat": {
      "foreground": "#336f3c"
    },
    "variable": {
      "foreground": "#8c4351",
      "fontStyle": "italic"
    },
    "variable.definition": {
      "foreground": "#8c4351",
      "fontStyle": "italic bold"
    },
    "variable.readonly": {
      "foreground": "#8c4351",
      "fontStyle": "italic"
    },
    "link": {
      "foreground": "#0e7490",
      "fontStyle": "underline"
    },
    "passageRef": {
      "foreground": "#0e7490"
    },
    "macro": {
      "foreground": "#34548a"
    },
    "macro.controlFlow": {
      "foreground": "#34548a",
      "fontStyle": "italic"
    },
    "macro.deprecated": {
      "foreground": "#34548a",
      "fontStyle": "strikethrough"
    },
    "macroDelimiter": {
      "foreground": "#5c6a7e"
    },
    "macroDelimiter.controlFlow": {
      "foreground": "#5c6a7e",
      "fontStyle": "italic"
    },
    "macroDelimiter.deprecated": {
      "foreground": "#5c6a7e",
      "fontStyle": "strikethrough"
    },
    "macroDelimiter.blockDepth1": {
      "foreground": "#34548a"
    },
    "macroDelimiter.blockDepth2": {
      "foreground": "#0e7490"
    },
    "macroDelimiter.blockDepth3": {
      "foreground": "#336f3c"
    },
    "macroDelimiter.blockDepth4": {
      "foreground": "#8c5a00"
    },
    "macroDelimiter.blockDepth5": {
      "foreground": "#8c4351"
    },
    "macroDelimiter.blockDepth6": {
      "foreground": "#6b3fa0"
    },
    "function": {
      "foreground": "#6b3fa0"
    },
    "function.definition": {
      "foreground": "#6b3fa0",
      "fontStyle": "bold"
    },
    "function.deprecated": {
      "foreground": "#6b3fa0",
      "fontStyle": "strikethrough"
    },
    "keyword": {
      "foreground": "#6b3fa0"
    },
    "namespace": {
      "foreground": "#0369a1",
      "fontStyle": "bold"
    },
    "property": {
      "foreground": "#0e7490"
    },
    "property.definition": {
      "foreground": "#0e7490",
      "fontStyle": "bold"
    },
    "operator": {
      "foreground": "#0369a1"
    },
    "operator.controlFlow": {
      "foreground": "#6b3fa0"
    },
    "string": {
      "foreground": "#336f3c"
    },
    "number": {
      "foreground": "#b85c00"
    },
    "boolean": {
      "foreground": "#b85c00"
    },
    "comment": {
      "foreground": "#5c6a7e",
      "fontStyle": "italic"
    }
  }
}
