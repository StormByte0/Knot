{
    "scopeName": "source.twee",
    "name": "Twee",
    "patterns": [
        {
            "comment": "Story JavaScript special passage — entire body is JavaScript. Shared across all Twine formats. Matches both 'Story JavaScript' and 'StoryJavascript', with or without [script] tag.",
            "contentName": "source.js.embedded.twee",
            "begin": "^(::)\\s*([Ss]tory\\s+[Jj]ava[Ss]cript)(?:\\s+\\[script\\])?\\s*(\\{.*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.passage.twee"
                },
                "2": {
                    "name": "entity.name.passage.special.twee"
                },
                "3": {
                    "name": "meta.passage.metadata.twee"
                }
            },
            "patterns": [
                {
                    "include": "source.js"
                }
            ]
        },
        {
            "comment": "Any passage with [script] tag — entire body is JavaScript. Covers user-named script passages like ':: MyCode [script]'.",
            "contentName": "source.js.embedded.twee",
            "begin": "^(::)\\s+(.*?)\\s+\\[script\\]\\s*(\\{.*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.passage.twee"
                },
                "2": {
                    "name": "entity.name.passage.special.twee"
                },
                "3": {
                    "name": "meta.passage.metadata.twee"
                }
            },
            "patterns": [
                {
                    "include": "source.js"
                }
            ]
        },
        {
            "comment": "Story Stylesheet special passage — entire body is CSS. Shared across all Twine formats.",
            "contentName": "source.css.embedded.twee",
            "begin": "^(::)\\s+([Ss]tory\\s?[Ss]tylesheet)(?:\\s+\\[stylesheet\\])?\\s*(\\{.*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.passage.twee"
                },
                "2": {
                    "name": "entity.name.passage.special.twee"
                },
                "3": {
                    "name": "meta.passage.metadata.twee"
                }
            },
            "patterns": [
                {
                    "include": "source.css"
                }
            ]
        },
        {
            "comment": "Any passage with [stylesheet] tag — entire body is CSS. Covers user-named stylesheet passages like ':: MyStyle [stylesheet]'.",
            "contentName": "source.css.embedded.twee",
            "begin": "^(::)\\s+(.*?)\\s+\\[stylesheet\\]\\s*(\\{.*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.passage.twee"
                },
                "2": {
                    "name": "entity.name.passage.special.twee"
                },
                "3": {
                    "name": "meta.passage.metadata.twee"
                }
            },
            "patterns": [
                {
                    "include": "source.css"
                }
            ]
        },
        {
            "comment": "StoryInterface special passage — entire body is HTML. SugarCube-specific but placed in base grammar for priority over generic header pattern.",
            "contentName": "text.html.embedded.twee",
            "begin": "^(::)\\s+([Ss]tory[Ii]nterface)\\s*(\\{.*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.passage.twee"
                },
                "2": {
                    "name": "entity.name.passage.special.twee"
                },
                "3": {
                    "name": "meta.passage.metadata.twee"
                }
            },
            "patterns": [
                {
                    "include": "text.html.basic"
                }
            ]
        },
        {
            "comment": "Passage header: :: Name [tags] {metadata}",
            "name": "meta.passage.header.twee",
            "match": "^(::)\\s+(.*?)(\\s+\\[([^\\]]*)\\])?\\s*(\\{.*\\})?\\s*$",
            "captures": {
                "1": {
                    "name": "punctuation.definition.passage.twee"
                },
                "2": {
                    "name": "entity.name.passage.twee"
                },
                "3": {
                    "name": "meta.tag.twee"
                },
                "4": {
                    "name": "entity.other.attribute-name.tag.twee"
                },
                "5": {
                    "name": "meta.passage.metadata.twee"
                }
            }
        },
        {
            "comment": "Block comment: /* ... */",
            "name": "comment.block.twee",
            "begin": "/\\*",
            "end": "\\*/",
            "captures": {
                "0": {
                    "name": "punctuation.definition.comment.twee"
                }
            }
        },
        {
            "comment": "Twine-style block comment: /% ... %/",
            "name": "comment.block.twine",
            "begin": "/%",
            "end": "%/",
            "captures": {
                "0": {
                    "name": "punctuation.definition.comment.twine"
                }
            }
        },
        {
            "comment": "HTML block comment: <!-- ... -->",
            "name": "comment.block.html",
            "begin": "<!--",
            "end": "-->",
            "captures": {
                "0": {
                    "name": "punctuation.definition.comment.html"
                }
            }
        },
        {
            "comment": "Arrow-style passage link: [[Display->Target]] (common to most Twine formats)",
            "match": "(\\[\\[)([^\\]]+?)(->)([^\\]]+?)(\\]\\])",
            "captures": {
                "1": {
                    "name": "punctuation.definition.link.begin.twee"
                },
                "2": {
                    "name": "string.other.link.display.twee"
                },
                "3": {
                    "name": "punctuation.separator.link.arrow.twee"
                },
                "4": {
                    "name": "markup.underline.link.target.twee"
                },
                "5": {
                    "name": "punctuation.definition.link.end.twee"
                }
            }
        },
        {
            "comment": "Pipe-style passage link: [[Display|Target]] (common to most Twine formats)",
            "match": "(\\[\\[)([^\\]]+?)(\\|)([^\\]]+?)(\\]\\])",
            "captures": {
                "1": {
                    "name": "punctuation.definition.link.begin.twee"
                },
                "2": {
                    "name": "string.other.link.display.twee"
                },
                "3": {
                    "name": "punctuation.separator.link.pipe.twee"
                },
                "4": {
                    "name": "markup.underline.link.target.twee"
                },
                "5": {
                    "name": "punctuation.definition.link.end.twee"
                }
            }
        },
        {
            "comment": "Simple passage link: [[Target]] (common to all Twine formats)",
            "match": "(\\[\\[)([^\\]|>-]+?)(\\]\\])",
            "captures": {
                "1": {
                    "name": "punctuation.definition.link.begin.twee"
                },
                "2": {
                    "name": "markup.underline.link.target.twee"
                },
                "3": {
                    "name": "punctuation.definition.link.end.twee"
                }
            }
        },
        {
            "comment": "HTML attribute: data-passage=\"value\" (used across all Twine formats)",
            "match": "(data-passage)\\s*(=)\\s*(\"[^\"]*\"|'[^']*')",
            "captures": {
                "1": {
                    "name": "entity.other.attribute-name.html.twee"
                },
                "2": {
                    "name": "punctuation.separator.key-value.html.twee"
                },
                "3": {
                    "name": "string.quoted.html.twee markup.underline.link.passageref.twee"
                }
            }
        },
        {
            "comment": "Story variable: $varName (used by SugarCube and Harlowe)",
            "name": "variable.other.story.twee",
            "match": "(?<!\\w)\\$[A-Za-z_][A-Za-z0-9_]*"
        }
    ]
}
