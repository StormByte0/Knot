{
    "scopeName": "source.sugarcube.twee",
    "name": "SugarCube (Twee)",
    "patterns": [
        {
            "comment": "====================================================================="
        },
        {
            "comment": "MINIMAL GRAMMAR — server-side semantic tokens are the primary color provider.",
            "name": "comment.section.minimal-grammar.sugarcube"
        },
        {
            "comment": "This grammar only handles: embedded language regions (script/style/JS-expr",
            "name": "comment.section.minimal-grammar.sugarcube"
        },
        {
            "comment": "macros), passage headers, comments, and macro delimiters (<< >>).",
            "name": "comment.section.minimal-grammar.sugarcube"
        },
        {
            "comment": "Everything else (variables, templates, operators, global objects, etc.)",
            "name": "comment.section.minimal-grammar.sugarcube"
        },
        {
            "comment": "is colored by the server's semantic token provider once it indexes.",
            "name": "comment.section.minimal-grammar.sugarcube"
        },
        {
            "comment": "====================================================================="
        },

        {
            "comment": "Script passage: :: Name [script] — entire body is JavaScript.",
            "contentName": "source.js.embedded.twee",
            "begin": "^(::)\\s+(\\S[^\\[]*?)\\s*\\[([^\\]]*\\bscript\\b[^\\]]*)\\]\\s*(\\{[^}]*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.passage.twee" },
                "2": { "name": "entity.name.passage.special.sugarcube" },
                "3": { "patterns": [{ "match": "\\bscript\\b", "name": "entity.other.attribute-name.tag.sugarcube" }, { "match": "[^\\s\\]]+", "name": "entity.other.attribute-name.tag.twee" }] },
                "4": { "name": "meta.passage.metadata.twee" }
            },
            "patterns": [{ "include": "source.js" }]
        },
        {
            "comment": "Stylesheet passage: :: Name [stylesheet] — entire body is CSS.",
            "contentName": "source.css.embedded.twee",
            "begin": "^(::)\\s+(\\S[^\\[]*?)\\s*\\[([^\\]]*\\bstylesheet\\b[^\\]]*)\\]\\s*(\\{[^}]*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.passage.twee" },
                "2": { "name": "entity.name.passage.special.sugarcube" },
                "3": { "patterns": [{ "match": "\\bstylesheet\\b", "name": "entity.other.attribute-name.tag.sugarcube" }, { "match": "[^\\s\\]]+", "name": "entity.other.attribute-name.tag.twee" }] },
                "4": { "name": "meta.passage.metadata.twee" }
            },
            "patterns": [{ "include": "source.css" }]
        },
        {
            "comment": "StoryInterface passage — entire body is HTML.",
            "contentName": "text.html.embedded.twee",
            "begin": "^(::)\\s+([Ss]tory[Ii]nterface)(?:\\s*\\[([^\\]]*)\\])?\\s*(\\{[^}]*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.passage.twee" },
                "2": { "name": "entity.name.passage.special.sugarcube" },
                "3": { "name": "entity.other.attribute-name.tag.twee" },
                "4": { "name": "meta.passage.metadata.twee" }
            },
            "patterns": [{ "include": "text.html.basic" }]
        },
        {
            "comment": "Story JavaScript special passage — entire body is JavaScript.",
            "contentName": "source.js.embedded.twee",
            "begin": "^(::)\\s+([Ss]tory\\s+[Jj]ava[Ss]cript)(?:\\s*\\[([^\\]]*)\\])?\\s*(\\{[^}]*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.passage.twee" },
                "2": { "name": "entity.name.passage.special.sugarcube" },
                "3": { "name": "entity.other.attribute-name.tag.twee" },
                "4": { "name": "meta.passage.metadata.twee" }
            },
            "patterns": [{ "include": "source.js" }]
        },
        {
            "comment": "Story Stylesheet special passage — entire body is CSS.",
            "contentName": "source.css.embedded.twee",
            "begin": "^(::)\\s+([Ss]tory\\s+[Ss]tylesheet)(?:\\s*\\[([^\\]]*)\\])?\\s*(\\{[^}]*\\})?\\s*$",
            "end": "^(?=\\s*::)|\\z",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.passage.twee" },
                "2": { "name": "entity.name.passage.special.sugarcube" },
                "3": { "name": "entity.other.attribute-name.tag.twee" },
                "4": { "name": "meta.passage.metadata.twee" }
            },
            "patterns": [{ "include": "source.css" }]
        },

        {
            "comment": "====================================================================="
        },
        {
            "comment": "Base Twee grammar — passage headers, links, comments.",
            "name": "comment.section.base-grammar-include.sugarcube"
        },
        {
            "include": "source.twee"
        },

        {
            "comment": "====================================================================="
        },
        {
            "comment": "Script block macro: <<script>> ... <</script>> — content is JavaScript",
            "contentName": "source.js.embedded.twee",
            "begin": "(<<)(script)(?:\\s+((?:[^>]|>[^>])*?))?(>>)",
            "end": "(<</)(script)(>>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" },
                "3": { "name": "variable.parameter.macro.sugarcube" },
                "4": { "name": "punctuation.definition.macro.end.sugarcube" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" },
                "3": { "name": "punctuation.definition.macro.end.sugarcube" }
            },
            "patterns": [{ "include": "source.js" }]
        },
        {
            "comment": "Style block macro: <<style>> ... <</style>> — content is CSS",
            "contentName": "source.css.embedded.twee",
            "begin": "(<<)(style)(?:\\s+((?:[^>]|>[^>])*?))?(>>)",
            "end": "(<</)(style)(>>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" },
                "3": { "name": "variable.parameter.macro.sugarcube" },
                "4": { "name": "punctuation.definition.macro.end.sugarcube" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" },
                "3": { "name": "punctuation.definition.macro.end.sugarcube" }
            },
            "patterns": [{ "include": "source.css" }]
        },

        {
            "comment": "====================================================================="
        },
        {
            "comment": "CONSOLIDATED JS-expression macros: <<set>>, <<if>>, <<elseif>>, <<run>>,",
            "name": "comment.section.consolidated-js-macros.sugarcube"
        },
        {
            "comment": "<<print>>, <<= >>, <<- >>, <<for>>, <<capture>>, <<switch>>, <<case>>.",
            "name": "comment.section.consolidated-js-macros.sugarcube"
        },
        {
            "comment": "All have JS expression args — content is JavaScript.",
            "name": "comment.section.consolidated-js-macros.sugarcube"
        },
        {
            "contentName": "source.js.embedded.twee",
            "begin": "(<<)(set|if|elseif|run|print|for|capture|switch|case|=|-)(?:\\s+)",
            "end": "(>>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.macro.end.sugarcube" }
            },
            "patterns": [{ "include": "source.js" }]
        },

        {
            "comment": "====================================================================="
        },
        {
            "comment": "Passage-name macros: <<include>>, <<goto>> — args are passage name strings",
            "name": "comment.section.passage-name-macros.sugarcube"
        },
        {
            "begin": "(<<)(include|goto)\\s+",
            "end": "(>>)",
            "beginCaptures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" }
            },
            "endCaptures": {
                "1": { "name": "punctuation.definition.macro.end.sugarcube" }
            },
            "patterns": [
                { "include": "#sugarcube-passage-name-string" },
                { "include": "source.js" }
            ]
        },

        {
            "comment": "====================================================================="
        },
        {
            "comment": "SugarCube closing macro tag: <</name>>",
            "name": "comment.section.close-tag.sugarcube"
        },
        {
            "match": "(<</)([A-Za-z_][A-Za-z0-9_]*)(>>)",
            "captures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" },
                "3": { "name": "punctuation.definition.macro.end.sugarcube" }
            }
        },
        {
            "comment": "SugarCube open macro tag: <<name args>> — generic fallback",
            "match": "(<<)([A-Za-z_][A-Za-z0-9_]*)(?:\\s+((?:[^>]|>[^>])*?))?(>>)",
            "captures": {
                "1": { "name": "punctuation.definition.macro.begin.sugarcube" },
                "2": { "name": "keyword.control.macro.sugarcube" },
                "3": { "name": "variable.parameter.macro.sugarcube" },
                "4": { "name": "punctuation.definition.macro.end.sugarcube" }
            }
        }
    ],
    "repository": {
        "sugarcube-passage-name-string": {
            "comment": "Passage name as a quoted string — used inside <<include>> and <<goto>>",
            "patterns": [
                {
                    "name": "string.quoted.double.js markup.underline.link.passageref.twee",
                    "match": "\"[^\"]*\""
                },
                {
                    "name": "string.quoted.single.js markup.underline.link.passageref.twee",
                    "match": "'[^']*'"
                }
            ]
        }
    }
}
